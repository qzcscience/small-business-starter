%%{init: {"theme": "base", "htmlLabels": true, "fontFamily": "Arial, sans-serif", "themeVariables": {"background": "transparent", "primaryColor": "#eff6ff", "primaryBorderColor": "#1b3a6b", "primaryTextColor": "#0f172a", "lineColor": "#64748b", "fontFamily": "Arial, sans-serif"}, "flowchart": {"useMaxWidth": false, "wrappingWidth": 280, "nodeSpacing": 70, "rankSpacing": 90, "curve": "basis"}}}%%
flowchart TD
    A["Manually load workpiece into chamber,<br/>connect the connectors"] --> B["Press start, chamber door close"]
    B --> C["Evacuate the chamber,<br/>Detect the workpiece pressure"]
    C --> D{"Gross leak check"}

    D -- NG --> E["Alarm, Vent workpiece,<br/>door open"]
    E --> F["Take out NG workpiece"]

    D -- OK --> G["Evacuate workpiece"]
    G --> H["Chamber & workpiece vacuum level reach;<br/>Workpiece He charging"]
    H --> I{"Helium leak check"}

    I -- NG --> J["Alarm;<br/>Helium recovery;<br/>Door open"]
    J --> K["Take out NG workpiece"]

    I -- OK --> L["Helium recovery"]
    L --> M["Evacuate workpiece"]
    M --> N["SF6 charging"]
    N --> O["Door open, take out workpiece"]

    classDef process fill:#eff6ff,stroke:#1b3a6b,color:#0f172a,stroke-width:1px;
    classDef decision fill:#fff7ed,stroke:#f97316,color:#0f172a,stroke-width:2px;
    classDef ng fill:#fef2f2,stroke:#b91c1c,color:#7f1d1d,stroke-width:1px;
    classDef ok fill:#f0fdf4,stroke:#15803d,color:#14532d,stroke-width:1px;

    class A,B,C,G,H,M,N process;
    class D,I decision;
    class E,F,J,K ng;
    class L,O ok;

    linkStyle 3,4,8,9 stroke:#b91c1c,stroke-width:2px;
    linkStyle 5,6,7,10,11,12,13 stroke:#15803d,stroke-width:2px;
