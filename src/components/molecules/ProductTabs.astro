---
interface Tab {
  id: string;
  label: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;

const tabsId = `tabs-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="product-tabs" data-tabs-id={tabsId}>
  <!-- Section Navigation -->
  <nav
    class="tabs-header sticky top-20 z-10 flex overflow-x-auto border-b border-border bg-white"
    aria-label="Product detail sections"
  >
    {tabs.map((tab, index) => (
      <a
        href={`#${tab.id}`}
        class:list={[
          'tab-btn flex min-w-[10rem] flex-1 items-center justify-center border-b-2 px-4 py-5 text-center text-base font-medium transition-colors sm:text-lg',
          index === 0 ? 'tab-btn-active border-primary text-primary' : 'border-transparent text-text-muted',
        ]}
        data-tab-target={tab.id}
        aria-current={index === 0 ? 'true' : undefined}
      >
        {tab.label}
      </a>
    ))}
  </nav>

  <!-- Tab Content Slots -->
  <div class="tabs-content">
    <slot />
  </div>
</div>

<script define:vars={{ tabsId }}>
  function initTabs() {
    const container = document.querySelector(`[data-tabs-id="${tabsId}"]`);
    if (!container || container.dataset.ready === 'true') return;

    const links = Array.from(container.querySelectorAll('.tab-btn'));
    const sections = links
      .map((link) => document.getElementById(link.getAttribute('data-tab-target')))
      .filter(Boolean);

    if (!links.length || !sections.length) return;

    function setActiveTab(activeId) {
      links.forEach((link) => {
        const isActive = link.getAttribute('data-tab-target') === activeId;

        link.classList.toggle('tab-btn-active', isActive);
        link.classList.toggle('border-primary', isActive);
        link.classList.toggle('text-primary', isActive);
        link.classList.toggle('border-transparent', !isActive);
        link.classList.toggle('text-text-muted', !isActive);
        link.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    }

    links.forEach((link) => {
      link.addEventListener('click', () => {
        const targetId = link.getAttribute('data-tab-target');
        if (targetId) setActiveTab(targetId);
      });
    });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

          if (visibleEntry?.target?.id) setActiveTab(visibleEntry.target.id);
        },
        { rootMargin: '-35% 0px -55% 0px' },
      );

      sections.forEach((section) => observer.observe(section));
    }

    container.dataset.ready = 'true';
  }

  initTabs();
  document.addEventListener('astro:after-swap', initTabs);
</script>

<style>
  .tab-btn {
    margin-bottom: -1px;
  }

  .tab-btn:hover {
    color: #333;
  }

  .tab-btn-active {
    color: #1f4396;
    border-bottom-color: #1f4396;
  }

  :global(.tab-content) {
    padding: 2rem 0;
    scroll-margin-top: 7rem;
  }

  :global(.tab-content + .tab-content) {
    border-top: 1px solid var(--color-border, #e5e7eb);
  }
</style>
