---
import CategorySidebar from '../atoms/CategorySidebar.astro';
import { NEWS_BASE_PATH, newsCategories } from '../../data/news';
import type { NewsTag } from '../../data/news';

interface Props {
  tags: NewsTag[];
  activeHref?: string;
  activeTagSlug?: string;
}

const { tags, activeHref, activeTagSlug } = Astro.props;
const categories = newsCategories.map(({ label, slug, href }) => ({ label, slug, href }));
---

<CategorySidebar
  title="News"
  rootHref={NEWS_BASE_PATH}
  categories={categories}
  activeHref={activeHref}
>
  <div class="border-t border-border bg-background">
    <div class="border-b border-border bg-surface/60 px-5 py-4">
      <h2 class="font-heading text-lg font-semibold uppercase leading-tight text-text">
        Tags
      </h2>
    </div>

    {tags.length > 0 ? (
      <nav aria-label="News tags" class="p-4">
        <ul class="flex flex-wrap gap-2">
          {tags.map((tag) => {
            const isActive = activeTagSlug === tag.slug;
            return (
              <li>
                <a
                  href={tag.href}
                  class:list={[
                    'inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1.5 text-xs font-semibold transition-colors',
                    isActive
                      ? 'border-primary bg-primary text-primary-fg'
                      : 'border-border bg-background text-text-muted hover:border-primary/40 hover:text-primary',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span>#{tag.label}</span>
                  <span class:list={[isActive ? 'text-primary-fg/75' : 'text-text-muted/70']}>
                    {tag.count}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    ) : (
      <p class="px-5 py-4 text-sm text-text-muted">No tags yet.</p>
    )}
  </div>
</CategorySidebar>
