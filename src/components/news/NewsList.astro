---
import NewsCard from './NewsCard.astro';
import type { NewsEntry } from '../../data/news';

interface Props {
  entries: NewsEntry[];
  emptyMessage?: string;
}

const { entries, emptyMessage = 'No news articles yet. Check back soon.' } = Astro.props;
---

{entries.length > 0 ? (
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
    {entries.map((entry) => (
      <NewsCard entry={entry} />
    ))}
  </div>
) : (
  <div class="rounded-lg border border-border bg-background p-8 text-center shadow-sm">
    <p class="text-text-muted">{emptyMessage}</p>
  </div>
)}
