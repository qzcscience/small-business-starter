---
import { getNewsCategory, getNewsHref, slugifyNewsTag } from '../../data/news';
import type { NewsEntry } from '../../data/news';

interface Props {
  entry: NewsEntry;
}

const { entry } = Astro.props;
const href = getNewsHref(entry);
const category = getNewsCategory(entry.data.category);
const formattedDate = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
  <a href={href} class="block" aria-label={entry.data.title}>
    <div class="aspect-[16/9] overflow-hidden bg-surface">
      {entry.data.image ? (
        <img
          src={entry.data.image}
          alt={entry.data.imageAlt || entry.data.title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-primary">
          <span class="px-6 text-center font-heading text-2xl font-bold uppercase leading-tight text-primary-fg">
            {category?.label || 'News'}
          </span>
        </div>
      )}
    </div>
  </a>

  <div class="flex min-h-[18rem] flex-col p-5 sm:p-6">
    <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">
      <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
      {category && (
        <>
          <span aria-hidden="true">&bull;</span>
          <a href={category.href} class="transition-colors hover:text-primary">
            {category.label}
          </a>
        </>
      )}
    </div>

    <h2 class="mt-3 font-heading text-h3 font-semibold uppercase leading-tight text-text transition-colors group-hover:text-primary">
      <a href={href}>{entry.data.title}</a>
    </h2>

    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
      {entry.data.description}
    </p>

    {entry.data.tags.length > 0 && (
      <ul class="mt-5 flex flex-wrap gap-2">
        {entry.data.tags.map((tag) => (
          <li>
            <a
              href={`/news/tag/${slugifyNewsTag(tag)}`}
              class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-semibold text-text-muted transition-colors hover:border-primary/40 hover:text-primary"
            >
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    )}

    <a
      href={href}
      class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors hover:text-primary-light"
    >
      Read more
      <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
