---
import { navItems } from '../config/nav';
import { brand } from '../config/brand';
import { logoImage } from '../config/images';

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm"
  transition:persist
>
  <div class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      {logoImage ? (
        <img src={logoImage.src} alt={brand.name} class="h-10 w-auto object-contain" />
      ) : (
        <span class="font-heading text-xl font-bold uppercase tracking-wide text-primary">
          {brand.name}
        </span>
      )}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary navigation">
      {navItems.map((item) => {
        const hasChildren = item.children && item.children.length > 0;
        const isActive = item.href && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)));

        return (
          <div class="relative group">
            {hasChildren ? (
              <button class="nav-item flex items-center gap-1 px-3 py-2 text-sm font-medium text-text-muted hover:text-text transition-colors">
                {item.label}
                <svg class="size-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            ) : (
              <a
                href={item.href}
                class:list={['nav-item px-3 py-2 text-sm font-medium transition-colors', isActive ? 'text-primary' : 'text-text-muted hover:text-text']}
              >
                {item.label}
              </a>
            )}

            {hasChildren && (
              <div class="dropdown-panel absolute left-0 top-full z-50 mt-1 min-w-[240px] rounded-md border border-border bg-background shadow-xl opacity-0 invisible -translate-y-2 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0">
                <div class="p-2">
                  <div class="flex flex-col gap-1">
                    {item.children!.map((child) => (
                      <a
                        href={child.href}
                        class="block rounded-md px-3 py-2 text-sm text-text-muted hover:bg-surface hover:text-text transition-colors whitespace-nowrap"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden items-center gap-4 lg:flex">
      <a
        href="/contact"
        class="inline-flex min-h-[44px] items-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Free Quote
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md text-text-muted hover:bg-surface lg:hidden"
    >
      <span class="sr-only">Toggle menu</span>
      <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background px-4 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
      {navItems.map((item) => {
        const hasChildren = item.children && item.children.length > 0;
        if (!hasChildren) {
          return (
            <a href={item.href} class="mobile-nav-link rounded-md px-3 py-3 text-base font-medium text-text-muted">
              {item.label}
            </a>
          );
        }
        return (
          <div class="mobile-dropdown">
            <button class="mobile-dropdown-toggle mobile-nav-link flex w-full items-center justify-between rounded-md px-3 py-3 text-base font-medium text-text-muted">
              {item.label}
              <svg class="size-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="mobile-dropdown-panel hidden pl-4">
              {item.children!.map((child) => (
                <a href={child.href} class="block rounded-md px-3 py-2 text-sm text-text-muted hover:bg-surface">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href="/contact"
        class="flex min-h-[44px] items-center justify-center rounded-md bg-accent px-5 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</header>

<style>
  .dropdown-panel {
    pointer-events: none;
  }
  .group:hover .dropdown-panel {
    pointer-events: auto;
  }
  .rotate-180 {
    transform: rotate(180deg);
  }
</style>

<script>
  // Mobile dropdown toggle
  document.querySelectorAll('.mobile-dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('svg');
      panel.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });

  // Close mobile dropdowns when clicking outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.mobile-dropdown')) {
      document.querySelectorAll('.mobile-dropdown-panel').forEach((p) => p.classList.add('hidden'));
      document.querySelectorAll('.mobile-dropdown-toggle svg').forEach((icon) => icon.classList.remove('rotate-180'));
    }
  });

  // Existing mobile menu toggle logic
  (() => {
    const headerEl = document.querySelector('header');
    const btnEl = document.getElementById('menu-toggle');
    const menuEl = document.getElementById('mobile-menu');
    const iconOpenEl = document.getElementById('menu-icon-open');
    const iconCloseEl = document.getElementById('menu-icon-close');

    if (!headerEl || !btnEl || !menuEl || !iconOpenEl || !iconCloseEl) return;

    const header = headerEl as HTMLElement;
    const btn = btnEl as HTMLButtonElement;
    const menu = menuEl as HTMLElement;
    const iconOpen = iconOpenEl as HTMLElement;
    const iconClose = iconCloseEl as HTMLElement;
    if (header.dataset.menuInit === 'true') return;
    header.dataset.menuInit = 'true';

    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    const setMenuOpen = (nextOpen: boolean) => {
      if (isDesktop()) nextOpen = false;
      btn.setAttribute('aria-expanded', String(nextOpen));
      menu.classList.toggle('hidden', !nextOpen);
      iconOpen.classList.toggle('hidden', nextOpen);
      iconClose.classList.toggle('hidden', !nextOpen);
    };

    function syncActiveLinks() {
      const path = window.location.pathname;
      const desktopLinks = header.querySelectorAll('nav[aria-label="Primary navigation"] a');
      const mobileLinks = header.querySelectorAll('#mobile-menu nav a');

      desktopLinks.forEach((link) => {
        const href = link.getAttribute('href') || '';
        const isActive = href === path || (href !== '/' && path.startsWith(href));
        link.classList.toggle('text-primary', isActive);
        link.classList.toggle('text-text-muted', !isActive);
      });

      mobileLinks.forEach((link) => {
        const href = link.getAttribute('href') || '';
        const isActive = href === path || (href !== '/' && path.startsWith(href));
        link.classList.toggle('text-primary', isActive);
        link.classList.toggle('bg-primary/10', isActive);
      });
    }

    btn.addEventListener('click', () => {
      if (isDesktop()) return;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      setMenuOpen(!isOpen);
    });

    menu.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('a[href]')) setMenuOpen(false);
    });

    document.addEventListener('astro:before-preparation', () => setMenuOpen(false));
    document.addEventListener('astro:after-swap', () => {
      setMenuOpen(false);
      syncActiveLinks();
    });

    window.addEventListener('resize', () => setMenuOpen(false));

    setMenuOpen(false);
    syncActiveLinks();
  })();
</script>
