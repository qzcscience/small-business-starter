---
import { brand } from '../config/brand';
import { client } from '../data/client';

const year = new Date().getFullYear();

const navCols = [
  {
    title: 'Company',
    links: [
      { label: 'About',    href: '/about' },
      { label: 'Services', href: '/services' },
      { label: 'Reviews',  href: '/reviews' },
      { label: 'Blog',     href: '/blog' },
    ],
  },
  {
    title: 'Support',
    links: [
      { label: 'Contact',  href: '/contact' },
      { label: 'Privacy',  href: '/privacy' },
      { label: 'Terms',    href: '/terms' },
    ],
  },
];
---

<footer class="bg-dark text-surface/80" transition:persist>
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="font-heading text-lg font-bold uppercase tracking-wide text-white">
          {brand.name}
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {brand.tagline}
        </p>

        <!-- Social links -->
        <div class="mt-5 flex items-center gap-4">
          {client.socials.facebook && (
            <a href={client.socials.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-surface/60 transition-colors hover:text-white">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" /></svg>
            </a>
          )}
          {client.socials.instagram && (
            <a href={client.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-surface/60 transition-colors hover:text-white">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
            </a>
          )}
          {client.socials.google && (
            <a href={client.socials.google} target="_blank" rel="noopener noreferrer" aria-label="Google Business" class="text-surface/60 transition-colors hover:text-white">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z" /></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Nav columns -->
      {navCols.map((col) => (
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-white">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm transition-colors hover:text-white">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Contact info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Contact</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={`tel:${client.phoneForTel}`} class="transition-colors hover:text-white">
              {client.phoneFormatted}
            </a>
          </li>
          <li>
            <a href={`mailto:${client.email}`} class="transition-colors hover:text-white">
              {client.email}
            </a>
          </li>
          <li>
            <a href={client.address.mapLink} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
              {client.address.lineOne}<br />
              {client.address.city}, {client.address.state} {client.address.zip}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-surface/10 pt-6 text-center text-sm">
      &copy; {year} {brand.name}. All rights reserved.
    </div>
  </div>
</footer>
