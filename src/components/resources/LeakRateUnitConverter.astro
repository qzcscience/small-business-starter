---
import { leakRateUnitConversionGroups } from '../../data/leakRateUnitConversions';

const unitDisplayLabels: Record<string, string> = {
  'Pa.m3/s': 'Pa&middot;m<sup>3</sup>/s',
  'mbar.l/s': 'mbar&middot;L/s',
  'torr.l/s': 'Torr&middot;L/s',
  'atm.cc/s': 'atm&middot;cc/s',
  'm3/hr': 'm<sup>3</sup>/hr',
  'l/sec': 'L/s',
  'l/min': 'L/min',
  ft3: 'ft<sup>3</sup>',
  inch3: 'in<sup>3</sup>',
  cm3: 'cm<sup>3</sup>',
  m3: 'm<sup>3</sup>',
  litr: 'L',
};

const getUnitLabel = (unit: string) => unitDisplayLabels[unit] ?? unit;

const formatNumber = (value: number, maximumSignificantDigits = 8) => {
  const absoluteValue = Math.abs(value);

  if (value === 0) return '0';
  if (absoluteValue < 1) {
    return value.toExponential(maximumSignificantDigits - 1).replace(/\.?0+e/, 'e');
  }

  return new Intl.NumberFormat('en-US', {
    maximumSignificantDigits,
  }).format(value);
};

const getDefaultResult = (group: (typeof leakRateUnitConversionGroups)[number]) => {
  const value = Number(group.defaultInput);
  const factor = group.factors[group.defaultFrom][group.defaultTo];

  return formatNumber(value * factor, 10);
};

const getDefaultFormula = (group: (typeof leakRateUnitConversionGroups)[number]) => {
  const value = Number(group.defaultInput);
  const factor = group.factors[group.defaultFrom][group.defaultTo];
  const convertedValue = value * factor;

  return `${formatNumber(value, 10)} ${getUnitLabel(group.defaultFrom)} x ${formatNumber(factor, 10)} = ${formatNumber(convertedValue, 10)} ${getUnitLabel(group.defaultTo)}`;
};
---

<div class="p-5 sm:p-6 lg:p-8">
  <div
    class="leak-rate-converter space-y-10"
    data-leak-rate-converter
  >
    <script
      id="leak-rate-converter-data"
      type="application/json"
      set:html={JSON.stringify(leakRateUnitConversionGroups)}
    ></script>

    <nav
      class="grid grid-cols-2 gap-2 lg:grid-cols-4"
      aria-label="Conversion groups"
    >
      {leakRateUnitConversionGroups.map((group) => (
        <a
          href={`#${group.id}`}
          class="converter-jump flex min-h-11 items-center justify-center px-3 py-2 text-center text-sm font-semibold"
          data-jump-link={group.id}
        >
          {group.label}
        </a>
      ))}
    </nav>

    {leakRateUnitConversionGroups.map((group, index) => (
      <section
        id={group.id}
        class:list={[
          'conversion-block',
          'scroll-mt-28',
          index === 0 ? '' : 'border-t border-border pt-10',
        ]}
        data-converter-block={group.id}
      >
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
              Conversion Tool
            </p>
            <h2 class="mt-2 font-heading text-h2 font-semibold uppercase leading-tight text-text">
              {group.label}
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-text-muted sm:text-base">
              {group.description}
            </p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] lg:items-start">
          <div>
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-heading text-h3 font-semibold uppercase leading-tight text-text">
                Source Unit
              </h3>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
              {group.units.map((unit) => (
                <button
                  type="button"
                  class="converter-unit min-h-11 px-3 py-2 text-sm font-semibold"
                  data-unit-role="from"
                  data-unit={unit}
                  data-active={unit === group.defaultFrom ? 'true' : 'false'}
                  aria-pressed={unit === group.defaultFrom ? 'true' : 'false'}
                >
                  <span set:html={getUnitLabel(unit)} />
                </button>
              ))}
            </div>
          </div>

          <div class="flex justify-center lg:pt-10">
            <button
              type="button"
              class="swap-button"
              data-swap-units
              aria-label="Swap units"
              title="Swap units"
            >
              <svg
                aria-hidden="true"
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 7h11" />
                <path d="m14 4 4 3-4 3" />
                <path d="M17 17H6" />
                <path d="m10 20-4-3 4-3" />
              </svg>
            </button>
          </div>

          <div>
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-heading text-h3 font-semibold uppercase leading-tight text-text">
                Target Unit
              </h3>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
              {group.units.map((unit) => (
                <button
                  type="button"
                  class="converter-unit min-h-11 px-3 py-2 text-sm font-semibold"
                  data-unit-role="to"
                  data-unit={unit}
                  data-active={unit === group.defaultTo ? 'true' : 'false'}
                  aria-pressed={unit === group.defaultTo ? 'true' : 'false'}
                >
                  <span set:html={getUnitLabel(unit)} />
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-5 grid grid-cols-1 gap-4 lg:grid-cols-2 lg:items-stretch">
          <div class="result-panel flex min-h-36 flex-col rounded-lg border border-border bg-surface p-3 sm:p-4" aria-live="polite">
            <div class="flex flex-1 flex-col">
              <label class="block">
                <span class="block min-h-4 text-xs font-semibold uppercase leading-4 tracking-[0.16em] text-text-muted">
                  Original Value
                </span>
                <span class="mt-3 flex min-h-14 overflow-hidden rounded-md border border-border bg-background transition-colors focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20">
                  <input
                    type="text"
                    inputmode="text"
                    autocomplete="off"
                    spellcheck="false"
                    value={group.defaultInput}
                    data-converter-input
                    aria-describedby={`converter-status-${group.id}`}
                    class="min-w-0 flex-1 border-0 bg-transparent px-4 py-3 text-lg font-semibold text-text outline-none"
                  />
                  <span
                    class="flex shrink-0 items-center border-l border-border bg-surface px-3 text-sm font-semibold text-text-muted"
                    data-input-unit
                    set:html={getUnitLabel(group.defaultFrom)}
                  />
                </span>
              </label>
            </div>
          </div>

          <div class="result-panel flex min-h-36 flex-col rounded-lg border border-border bg-surface p-3 sm:p-4" aria-live="polite">
            <div class="flex flex-1 flex-col">
              <p class="min-h-4 text-xs font-semibold uppercase leading-4 tracking-[0.16em] text-text-muted">
                Converted Result
              </p>
              <div
                class="mt-3 flex min-h-14 overflow-hidden rounded-md border border-border bg-surface"
                data-converter-result
              >
                <span
                  class="min-w-0 flex-1 bg-surface px-4 py-3 text-lg font-semibold text-text"
                  data-converter-result-value
                >
                  {getDefaultResult(group)}
                </span>
                <span
                  class="flex shrink-0 items-center border-l border-border bg-surface px-3 text-sm font-semibold text-text-muted"
                  data-converter-result-unit
                  set:html={getUnitLabel(group.defaultTo)}
                />
              </div>
              <p
                id={`converter-status-${group.id}`}
                class="mt-2 break-words text-sm leading-snug text-text-muted"
                data-converter-status
                set:html={getDefaultFormula(group)}
              />
            </div>
          </div>
        </div>

        <div class="mt-8 overflow-x-auto rounded-lg border border-border bg-background">
          <table class="min-w-full border-collapse text-left text-sm">
            <caption class="sr-only">
              {group.label} conversion factors
            </caption>
            <thead class="bg-surface">
              <tr>
                <th scope="col" class="min-w-36 border-b border-border px-4 py-3 font-semibold text-text">
                  Unit
                </th>
                {group.units.map((unit) => (
                  <th scope="col" class="min-w-28 border-b border-border px-4 py-3 font-semibold text-text">
                    <span set:html={getUnitLabel(unit)} />
                  </th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {group.units.map((fromUnit) => (
                <tr>
                  <th scope="row" class="whitespace-nowrap bg-surface/60 px-4 py-3 font-semibold text-text">
                    1 <span set:html={getUnitLabel(fromUnit)} />
                  </th>
                  {group.units.map((toUnit) => (
                    <td class="whitespace-nowrap px-4 py-3 font-medium text-text-muted">
                      {formatNumber(group.factors[fromUnit][toUnit])}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}
  </div>
</div>

<style>
  .converter-jump,
  .converter-unit {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-background);
    color: var(--color-text);
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease;
  }

  .converter-jump:hover,
  .converter-unit:hover {
    border-color: color-mix(in srgb, var(--color-primary) 50%, var(--color-border));
    color: var(--color-primary);
  }

  .converter-jump:focus-visible,
  .converter-unit:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .converter-unit[data-active='true'] {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: var(--color-primary-fg);
    box-shadow: 0 10px 24px rgb(15 23 42 / 10%);
  }

  .swap-button {
    display: inline-flex;
    min-height: 2.75rem;
    min-width: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-background);
    color: var(--color-primary);
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease;
  }

  .swap-button:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: var(--color-primary-fg);
    box-shadow: 0 10px 24px rgb(15 23 42 / 10%);
  }

  .swap-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .leak-rate-converter sup {
    font-size: 0.68em;
    line-height: 0;
    vertical-align: super;
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-leak-rate-converter]');
    const dataNode = document.getElementById('leak-rate-converter-data');

    if (!(root instanceof HTMLElement) || !dataNode?.textContent) return;

    const groups = JSON.parse(dataNode.textContent);
    const unitLabels = {
      'Pa.m3/s': 'Pa&middot;m<sup>3</sup>/s',
      'mbar.l/s': 'mbar&middot;L/s',
      'torr.l/s': 'Torr&middot;L/s',
      'atm.cc/s': 'atm&middot;cc/s',
      'm3/hr': 'm<sup>3</sup>/hr',
      'l/sec': 'L/s',
      'l/min': 'L/min',
      ft3: 'ft<sup>3</sup>',
      inch3: 'in<sup>3</sup>',
      cm3: 'cm<sup>3</sup>',
      m3: 'm<sup>3</sup>',
      litr: 'L',
    };
    const unitLabel = (unit) => unitLabels[unit] || unit;

    const formatValue = (value) => {
      const absoluteValue = Math.abs(value);

      if (value === 0) return '0';
      if (absoluteValue < 1) {
        return value.toExponential(8).replace(/\.?0+e/, 'e');
      }

      return new Intl.NumberFormat('en-US', {
        maximumSignificantDigits: 10,
      }).format(value);
    };

    const setActive = (block, selector, activePredicate) => {
      block.querySelectorAll(selector).forEach((element) => {
        if (!(element instanceof HTMLElement)) return;

        const isActive = activePredicate(element);
        element.dataset.active = String(isActive);
        element.setAttribute('aria-pressed', String(isActive));
      });
    };

    root.querySelectorAll('[data-converter-block]').forEach((block) => {
      if (!(block instanceof HTMLElement)) return;

      const group = groups.find((candidate) => candidate.id === block.dataset.converterBlock);
      const input = block.querySelector('[data-converter-input]');
      const inputUnit = block.querySelector('[data-input-unit]');
      const convertedResultValue = block.querySelector('[data-converter-result-value]');
      const convertedResultUnit = block.querySelector('[data-converter-result-unit]');
      const convertedStatus = block.querySelector('[data-converter-status]');
      const swapButton = block.querySelector('[data-swap-units]');

      if (
        !group ||
        !(input instanceof HTMLInputElement) ||
        !(inputUnit instanceof HTMLElement) ||
        !(convertedResultValue instanceof HTMLElement) ||
        !(convertedResultUnit instanceof HTMLElement) ||
        !(convertedStatus instanceof HTMLElement) ||
        !(swapButton instanceof HTMLButtonElement)
      ) {
        return;
      }

      const state = {
        from: group.defaultFrom,
        to: group.defaultTo,
      };

      const updateResult = () => {
        const rawValue = input.value.trim();
        const value = Number(rawValue);
        inputUnit.innerHTML = unitLabel(state.from);
        convertedResultUnit.innerHTML = unitLabel(state.to);

        if (!rawValue || !Number.isFinite(value)) {
          convertedResultValue.textContent = 'Ready';
          convertedStatus.textContent = 'Enter a valid number to convert.';
          return;
        }

        const factor = group.factors[state.from]?.[state.to];

        if (!Number.isFinite(factor)) {
          convertedResultValue.textContent = 'Ready';
          convertedStatus.textContent = 'Select source and target units.';
          return;
        }

        const convertedValue = value * factor;

        convertedResultValue.textContent = formatValue(convertedValue);
        convertedStatus.innerHTML = `${formatValue(value)} ${unitLabel(state.from)} x ${formatValue(factor)} = ${formatValue(convertedValue)} ${unitLabel(state.to)}`;
      };

      const render = () => {
        setActive(block, '[data-unit-role="from"]', (element) => element.dataset.unit === state.from);
        setActive(block, '[data-unit-role="to"]', (element) => element.dataset.unit === state.to);
        updateResult();
      };

      block.querySelectorAll('[data-unit-role]').forEach((button) => {
        button.addEventListener('click', () => {
          const role = button.dataset.unitRole;
          const unit = button.dataset.unit;

          if (!unit) return;
          if (role === 'from') state.from = unit;
          if (role === 'to') state.to = unit;
          render();
        });
      });

      input.addEventListener('input', updateResult);
      swapButton.addEventListener('click', () => {
        const rawValue = input.value.trim();
        const value = Number(rawValue);
        const factor = group.factors[state.from]?.[state.to];

        if (rawValue && Number.isFinite(value) && Number.isFinite(factor)) {
          input.value = formatValue(value * factor);
        }

        const previousFrom = state.from;
        state.from = state.to;
        state.to = previousFrom;
        render();
      });

      render();
    });
  })();
</script>
