---
import CategorySidebarItem from './CategorySidebarItem.astro';

interface CategoryChild {
  label: string;
  href: string;
  children?: CategoryChild[];
}

interface Category {
  label: string;
  href?: string;
  children?: Category[];
}

interface Props {
  title?: string;
  categories: Category[];
  rootHref?: string;
  activeHref?: string;
  activeSlug?: string;
  collapsible?: boolean;
}

const {
  title = 'Products',
  categories,
  rootHref = '/products',
  activeHref,
  activeSlug,
  collapsible = false,
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizedRootHref = rootHref.replace(/\/$/, '') || '/';
const isRootIndex = currentPath === normalizedRootHref;
---

<aside class="category-sidebar hidden shrink-0 lg:block lg:w-[17.5rem] xl:w-[18.5rem]">
  <div class="sticky top-28 overflow-hidden rounded-lg border border-border bg-background">
    <a
      href={rootHref}
      class:list={[
        'block border-b border-border px-5 py-4 transition-colors',
        isRootIndex ? 'bg-surface text-text' : 'bg-background text-text hover:text-primary',
      ]}
      aria-current={isRootIndex ? 'page' : undefined}
    >
      <h2 class="font-heading text-lg font-semibold uppercase leading-tight">
        {title}
      </h2>
    </a>

    <nav aria-label={title} class="bg-background">
      <ul class="divide-y divide-border">
        {categories.map((category) => (
          <CategorySidebarItem
            category={category}
            activeHref={activeHref}
            activeSlug={activeSlug}
            collapsible={collapsible}
          />
        ))}
      </ul>
    </nav>

    <slot />
  </div>
</aside>

<script>
  (() => {
    const initKey = '__categorySidebarCollapse';

    if (window[initKey]) return;
    window[initKey] = true;

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const toggle = target.closest('.category-sidebar-toggle');
      if (!(toggle instanceof HTMLButtonElement)) return;

      const panelId = toggle.getAttribute('aria-controls');
      if (!panelId) return;

      const panel = document.getElementById(panelId);
      if (!(panel instanceof HTMLElement)) return;

      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      const nextExpanded = !isExpanded;
      const icon = toggle.querySelector('[data-sidebar-toggle-icon]');

      toggle.setAttribute('aria-expanded', String(nextExpanded));
      panel.hidden = !nextExpanded;
      if (icon) icon.textContent = nextExpanded ? '-' : '+';
    });
  })();
</script>
