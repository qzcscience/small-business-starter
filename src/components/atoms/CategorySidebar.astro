---
interface CategoryChild {
  label: string;
  href: string;
}

interface Category {
  label: string;
  href?: string;
  children?: CategoryChild[];
}

interface Props {
  title?: string;
  categories: Category[];
  activeHref?: string;
  activeSlug?: string;
}

const {
  title = 'Products',
  categories,
  activeHref,
  activeSlug,
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isProductsIndex = currentPath === '/products';

const isCurrentPath = (href?: string) => {
  if (!href) return false;
  if (activeHref) return href === activeHref;

  return Boolean(activeSlug && href.includes(activeSlug));
};
---

<aside class="hidden lg:block lg:w-[17.5rem] xl:w-[18.5rem] shrink-0">
  <div class="sticky top-28 overflow-hidden rounded-lg border border-border bg-background">
    <a
      href="/products"
      class:list={[
        'block border-b border-border px-5 py-4 transition-colors',
        isProductsIndex ? 'bg-surface text-text' : 'bg-background text-text hover:text-primary',
      ]}
      aria-current={isProductsIndex ? 'page' : undefined}
    >
      <h2 class="font-heading text-lg font-semibold uppercase leading-tight">
        {title}
      </h2>
    </a>

    <nav aria-label={title} class="bg-background">
      <ul class="divide-y divide-border">
        {categories.map((category) => {
          const isActive = isCurrentPath(category.href);
          const hasActiveChild = category.children?.some((child) => isCurrentPath(child.href));

          return (
            <li>
              <a
                href={category.href || '#'}
                class:list={[
                  'block border-l-2 px-5 py-3 text-[0.95rem] font-semibold leading-snug transition-colors',
                  isActive
                    ? 'border-primary bg-surface text-text'
                    : hasActiveChild
                      ? 'border-primary bg-background text-text'
                      : 'border-transparent bg-background text-text hover:text-primary',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {category.label}
              </a>

              {category.children && category.children.length > 0 && (
                <ul class="border-t border-border bg-background py-1">
                  {category.children.map((child) => {
                    const isChildActive = isCurrentPath(child.href);

                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block border-l-2 px-7 py-2.5 text-sm leading-snug transition-colors',
                            isChildActive
                              ? 'border-primary bg-surface font-medium text-text'
                              : 'border-transparent bg-background text-text-muted hover:text-text',
                          ]}
                          aria-current={isChildActive ? 'page' : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</aside>
