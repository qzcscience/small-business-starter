---
interface CategoryChild {
  label: string;
  href: string;
}

interface Category {
  label: string;
  href?: string;
  children?: CategoryChild[];
}

interface Props {
  title?: string;
  eyebrow?: string;
  categories: Category[];
  activeHref?: string;
  activeSlug?: string;
}

const {
  title = 'Browse Products',
  eyebrow = 'Catalog',
  categories,
  activeHref,
  activeSlug,
} = Astro.props;

const isCurrentPath = (href?: string) => {
  if (!href) return false;
  if (activeHref) return href === activeHref;

  return Boolean(activeSlug && href.includes(activeSlug));
};
---

<aside class="hidden lg:block lg:w-[17.5rem] xl:w-[18.5rem] shrink-0">
  <div class="sticky top-28 overflow-hidden rounded-lg border border-border bg-background">
    <div class="border-b border-border bg-surface px-5 py-4">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-text-muted">
        {eyebrow}
      </p>
      <h2 class="mt-1.5 font-heading text-lg font-semibold uppercase leading-tight text-text">
        {title}
      </h2>
    </div>

    <nav aria-label={title} class="bg-background">
      <ul class="divide-y divide-border">
        {categories.map((category) => {
          const isActive = isCurrentPath(category.href);
          const hasActiveChild = category.children?.some((child) => isCurrentPath(child.href));

          return (
            <li>
              <a
                href={category.href || '#'}
                class:list={[
                  'block border-l-2 px-5 py-3 text-[0.95rem] font-semibold leading-snug transition-colors',
                  isActive || hasActiveChild
                    ? 'border-primary bg-surface text-text'
                    : 'border-transparent text-text hover:bg-surface',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {category.label}
              </a>

              {category.children && category.children.length > 0 && (
                <ul class="border-t border-border bg-surface/70 py-1">
                  {category.children.map((child) => {
                    const isChildActive = isCurrentPath(child.href);

                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block border-l-2 px-7 py-2.5 text-sm leading-snug transition-colors',
                            isChildActive
                              ? 'border-primary bg-background font-medium text-text'
                              : 'border-transparent text-text-muted hover:bg-background hover:text-text',
                          ]}
                          aria-current={isChildActive ? 'page' : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</aside>
