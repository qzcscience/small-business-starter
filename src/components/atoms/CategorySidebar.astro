---
interface CategoryChild {
  label: string;
  href: string;
}

interface Category {
  label: string;
  href?: string;
  children?: CategoryChild[];
}

interface Props {
  title?: string;
  eyebrow?: string;
  categories: Category[];
  activeSlug?: string;
}

const {
  title = 'Browse Products',
  eyebrow = 'Catalog',
  categories,
  activeSlug,
} = Astro.props;
---

<aside class="hidden lg:block lg:w-[17.5rem] xl:w-[18.5rem] shrink-0">
  <div class="sticky top-28 overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
    <div class="bg-linear-to-br from-primary to-primary-light px-6 py-5 text-primary-fg">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-primary-fg/70">
        {eyebrow}
      </p>
      <h2 class="mt-2 font-heading text-[1.35rem] font-semibold uppercase leading-tight text-primary-fg">
        {title}
      </h2>
    </div>

    <nav aria-label={title} class="p-3">
      <ul class="space-y-2">
        {categories.map((category) => {
          const isActive = category.href?.includes(activeSlug || '');
          const hasActiveChild = category.children?.some((child) => child.href.includes(activeSlug || ''));

          return (
            <li class="rounded-xl border border-border/70 bg-surface/55 p-1.5 transition-colors">
              <a
                href={category.href || '#'}
                class:list={[
                  'group flex items-center justify-between gap-3 rounded-lg px-4 py-3.5 text-[0.95rem] font-semibold transition-all duration-200',
                  isActive || hasActiveChild
                    ? 'bg-primary text-primary-fg shadow-sm'
                    : 'text-text hover:bg-background hover:text-primary',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                <span class="leading-snug">{category.label}</span>
                <svg
                  class:list={[
                    'size-4 shrink-0 transition-transform duration-200',
                    isActive || hasActiveChild ? 'text-primary-fg' : 'text-text-muted group-hover:translate-x-0.5 group-hover:text-primary',
                  ]}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>

              {category.children && category.children.length > 0 && (
                <ul class="mt-2 space-y-1.5 px-1 pb-1">
                  {category.children.map((child) => {
                    const isChildActive = child.href.includes(activeSlug || '');

                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'group flex items-center justify-between gap-3 rounded-lg px-4 py-3 text-sm transition-all duration-200',
                            isChildActive
                              ? 'bg-primary/10 font-medium text-primary'
                              : 'text-text-muted hover:bg-background hover:text-text',
                          ]}
                          aria-current={isChildActive ? 'page' : undefined}
                        >
                          <span class="leading-snug">{child.label}</span>
                          <svg
                            class:list={[
                              'size-3.5 shrink-0 transition-transform duration-200',
                              isChildActive
                                ? 'text-primary'
                                : 'text-text-muted/70 group-hover:translate-x-0.5 group-hover:text-text',
                            ]}
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                          >
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</aside>
