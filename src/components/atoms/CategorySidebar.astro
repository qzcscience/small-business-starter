---
interface CategoryChild {
  label: string;
  href: string;
}

interface Category {
  label: string;
  href?: string;
  children?: CategoryChild[];
}

interface Props {
  categories: Category[];
  activeSlug?: string;
}

const { categories, activeSlug } = Astro.props;
---

<aside class="hidden lg:block w-[300px] flex-shrink-0">
  <div class="category-sidebar">
    <ul class="space-y-1">
      {categories.map((category) => {
        const isActive = category.href?.includes(activeSlug || '');
        const hasActiveChild = category.children?.some(child => child.href.includes(activeSlug || ''));

        return (
          <li class:list={['category-item', { 'is-open': hasActiveChild, 'is-active': isActive }]}>
            <a
              href={category.href || '#'}
              class:list={['category-link', { 'has-active': hasActiveChild }]}
            >
              <span class="flex-1">{category.label}</span>
              {category.children && category.children.length > 0 && (
                <span class="expand-icon">
                  <svg class="icon-expand size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
                  </svg>
                  <svg class="icon-collapse size-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                  </svg>
                </span>
              )}
            </a>
            {category.children && category.children.length > 0 && (
              <ul class="subcategory-list hidden">
                {category.children.map((child) => {
                  const isChildActive = child.href.includes(activeSlug || '');
                  return (
                    <li>
                      <a
                        href={child.href}
                        class:list={['subcategory-link', { 'is-active': isChildActive }]}
                      >
                        {child.label}
                        <svg class="arrow-icon size-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </div>
</aside>

<style>
  .category-sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .category-item {
    margin-bottom: 4px;
    border-radius: 6px;
    overflow: hidden;
  }

  .category-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 40px 15px 20px;
    background: linear-gradient(to left, #f5f5f5, #edeef5);
    color: #333;
    font-size: 16px;
    position: relative;
    transition: all 0.2s ease;
  }

  .category-link:hover {
    background: linear-gradient(to left, #e8e8ee, #dcdce5);
  }

  .category-item.is-active > .category-link {
    background: #1f4396;
    color: #fff;
  }

  .category-item.is-open > .category-link,
  .category-item.is-open > .category-link .icon-expand {
    background: #ee7700;
    color: #fff;
  }

  .expand-icon {
    display: flex;
    align-items: center;
  }

  .category-item.is-open .expand-icon .icon-expand {
    display: none;
  }

  .category-item.is-open .expand-icon .icon-collapse {
    display: block;
  }

  .subcategory-list {
    background: #fff;
    border-radius: 0 0 6px 6px;
    overflow: hidden;
  }

  .category-item.is-open > .subcategory-list,
  .category-item.is-active > .subcategory-list {
    display: block;
  }

  .subcategory-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 40px 15px 20px;
    color: #666;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .subcategory-link:hover {
    color: #1f4396;
  }

  .subcategory-link.is-active {
    color: #1f4396;
    font-weight: 500;
  }

  .arrow-icon {
    opacity: 0.5;
  }

  .subcategory-link:hover .arrow-icon,
  .subcategory-link.is-active .arrow-icon {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll('.category-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      const categoryItem = link.closest('.category-item');
      if (!categoryItem) return;

      const hasChildren = categoryItem.querySelector('.subcategory-list');
      if (!hasChildren) return;

      e.preventDefault();

      const isOpen = categoryItem.classList.contains('is-open');

      // Close all
      document.querySelectorAll('.category-item').forEach((item) => {
        item.classList.remove('is-open');
      });

      // Toggle current
      if (!isOpen) {
        categoryItem.classList.add('is-open');
      }
    });
  });
</script>
