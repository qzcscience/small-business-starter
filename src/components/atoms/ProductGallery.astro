---
interface GalleryImage {
  src: string;
  alt?: string;
}

interface Props {
  images: GalleryImage[];
  videoSrc?: string;
}

const { images, videoSrc } = Astro.props;

const galleryId = `gallery-${Math.random().toString(36).substring(2, 9)}`;
const videoPoster = images[0];
const slides = [
  ...(videoSrc
    ? [
        {
          type: 'video',
          src: videoSrc,
          alt: 'Product video',
          posterSrc: videoPoster?.src,
          posterAlt: videoPoster?.alt || 'Product video poster',
        },
      ]
    : []),
  ...images.map((image, index) => ({
    type: 'image',
    src: image.src,
    alt: image.alt || `Product image ${index + 1}`,
  })),
];
const hasMultipleSlides = slides.length > 1;
---

<div
  class="product-gallery overflow-hidden rounded-lg border border-border bg-background"
  data-gallery-id={galleryId}
>
  <div class="relative overflow-hidden border-b border-border bg-surface">
    <div class="gallery-track flex transition-transform duration-300 ease-out">
      {slides.map((slide, index) => (
        <figure class="gallery-slide flex min-w-full items-center justify-center [aspect-ratio:4/3] p-4 sm:p-6">
          {slide.type === 'video' ? (
            <div
              class="relative h-full w-full overflow-hidden rounded-md border border-border bg-background"
              data-video-slide
              data-video-src={slide.src}
              data-video-title="Product video"
            >
              {slide.posterSrc ? (
                <img
                  src={slide.posterSrc}
                  alt={slide.posterAlt}
                  class="size-full object-contain"
                  loading="eager"
                  decoding="async"
                  data-video-poster
                />
              ) : (
                <div class="flex size-full items-center justify-center bg-surface text-sm font-medium text-text-muted" data-video-poster>
                  Product video
                </div>
              )}
              <div
                class="absolute inset-0 bg-linear-to-t from-dark/35 via-dark/5 to-transparent"
                aria-hidden="true"
                data-video-overlay
              />
              <button
                type="button"
                class="absolute inset-0 flex items-center justify-center text-white focus-visible:outline-2 focus-visible:outline-offset-[-6px] focus-visible:outline-primary"
                aria-label="Play product video"
                data-video-button
              >
                <span class="flex size-14 items-center justify-center rounded-full bg-primary text-white shadow-lg transition-transform duration-200 hover:scale-105 sm:size-16">
                  <svg class="ml-1 size-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </button>
            </div>
          ) : (
            <img
              src={slide.src}
              alt={slide.alt}
              class="h-full w-full object-contain"
              loading={index === 0 ? 'eager' : 'lazy'}
            />
          )}
        </figure>
      ))}
    </div>

    {hasMultipleSlides && (
      <>
        <button
          type="button"
          class="gallery-prev absolute left-3 top-1/2 inline-flex size-10 -translate-y-1/2 items-center justify-center rounded-md border border-border bg-background/90 text-text-muted transition-colors hover:bg-background hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          aria-label="Previous product media"
        >
          <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          type="button"
          class="gallery-next absolute right-3 top-1/2 inline-flex size-10 -translate-y-1/2 items-center justify-center rounded-md border border-border bg-background/90 text-text-muted transition-colors hover:bg-background hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          aria-label="Next product media"
        >
          <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </>
    )}

    <div class="absolute bottom-3 right-3 rounded-md border border-border bg-background/90 px-2.5 py-1 text-xs font-medium text-text-muted">
      <span class="gallery-current">1</span>
      <span aria-hidden="true">/</span>
      <span>{slides.length}</span>
    </div>
  </div>

  {hasMultipleSlides && (
    <div class="bg-background p-3">
      <div class="grid grid-cols-5 gap-2">
        {slides.map((slide, index) => (
          <button
            type="button"
            class:list={[
              'gallery-thumb overflow-hidden rounded-md border bg-surface transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
              index === 0 ? 'is-active border-primary' : 'border-border hover:border-primary/60',
            ]}
            data-slide-index={index}
            aria-label={`Show product media ${index + 1}`}
            aria-current={index === 0 ? 'true' : undefined}
          >
            <span class="flex [aspect-ratio:1/1] items-center justify-center p-1.5">
              {slide.type === 'video' ? (
                <span class="inline-flex size-9 items-center justify-center rounded-md border border-border bg-background text-text-muted">
                  <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              ) : (
                <img
                  src={slide.src}
                  alt=""
                  class="h-full w-full object-contain"
                  loading="lazy"
                />
              )}
            </span>
          </button>
        ))}
      </div>
    </div>
  )}
</div>

<script define:vars={{ galleryId }}>
  function initGallery() {
    const gallery = document.querySelector(`[data-gallery-id="${galleryId}"]`);
    if (!gallery || gallery.dataset.ready === 'true') return;

    const track = gallery.querySelector('.gallery-track');
    const currentLabel = gallery.querySelector('.gallery-current');
    const prevButton = gallery.querySelector('.gallery-prev');
    const nextButton = gallery.querySelector('.gallery-next');
    const thumbs = Array.from(gallery.querySelectorAll('.gallery-thumb'));
    const slideCount = gallery.querySelectorAll('.gallery-slide').length;
    const videoButtons = Array.from(gallery.querySelectorAll('[data-video-button]'));

    if (!track || slideCount === 0) return;

    let activeIndex = 0;

    function getAutoplaySrc(src) {
      try {
        const url = new URL(src, window.location.href);
        url.searchParams.set('autoplay', '1');
        url.searchParams.set('rel', '0');
        return url.toString();
      } catch {
        const separator = src.includes('?') ? '&' : '?';
        return `${src}${separator}autoplay=1&rel=0`;
      }
    }

    function loadVideo(button) {
      const video = button.closest('[data-video-slide]');
      const videoSrc = video?.dataset.videoSrc;
      if (!video || !videoSrc || video.dataset.videoLoaded === 'true') return;

      const iframe = document.createElement('iframe');
      iframe.src = getAutoplaySrc(videoSrc);
      iframe.title = video.dataset.videoTitle || 'Product video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.className = 'absolute inset-0 size-full border-0 bg-background';

      video.querySelector('[data-video-poster]')?.remove();
      video.querySelector('[data-video-overlay]')?.remove();
      button.remove();
      video.dataset.videoLoaded = 'true';
      video.append(iframe);
    }

    function setActiveSlide(nextIndex) {
      activeIndex = (nextIndex + slideCount) % slideCount;
      track.style.transform = `translateX(-${activeIndex * 100}%)`;
      if (currentLabel) currentLabel.textContent = String(activeIndex + 1);

      thumbs.forEach((thumb, index) => {
        const isActive = index === activeIndex;
        thumb.classList.toggle('is-active', isActive);
        thumb.classList.toggle('border-primary', isActive);
        thumb.classList.toggle('border-border', !isActive);
        thumb.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    }

    prevButton?.addEventListener('click', () => setActiveSlide(activeIndex - 1));
    nextButton?.addEventListener('click', () => setActiveSlide(activeIndex + 1));
    videoButtons.forEach((button) => {
      button.addEventListener('click', () => loadVideo(button));
    });
    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = Number(thumb.getAttribute('data-slide-index'));
        if (Number.isInteger(index)) setActiveSlide(index);
      });
    });

    gallery.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') setActiveSlide(activeIndex - 1);
      if (event.key === 'ArrowRight') setActiveSlide(activeIndex + 1);
    });

    gallery.dataset.ready = 'true';
    setActiveSlide(0);
  }

  initGallery();
  document.addEventListener('astro:after-swap', initGallery);
</script>

<style>
  .product-gallery {
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.04);
  }

  .gallery-thumb {
    opacity: 0.72;
  }

  .gallery-thumb.is-active,
  .gallery-thumb:hover {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-track {
      transition: none;
    }
  }
</style>
