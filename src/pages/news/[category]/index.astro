---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import CTA from '../../../components/CTA.astro';
import NewsList from '../../../components/news/NewsList.astro';
import NewsSidebar from '../../../components/news/NewsSidebar.astro';
import {
  NEWS_BASE_PATH,
  getNewsTags,
  getPublishedNews,
  newsCategories,
} from '../../../data/news';

export async function getStaticPaths() {
  return newsCategories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const allEntries = await getPublishedNews();
const entries = allEntries.filter((entry) => entry.data.category === category.slug);
const tags = getNewsTags(allEntries);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'News', href: NEWS_BASE_PATH },
  { label: category.label },
];
---

<BaseLayout
  title={`${category.label} News`}
  description={category.description}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <NewsSidebar tags={tags} activeHref={category.href} />

        <div class="min-w-0 flex-1">
          <div class="mb-8 rounded-lg border border-border bg-background px-6 py-6 shadow-sm sm:px-8">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
              News Category
            </p>
            <h1 class="mt-3 font-heading text-h1 font-bold uppercase leading-tight text-text">
              {category.label}
            </h1>
            <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
              {category.description}
            </p>
          </div>

          <NewsList
            entries={entries}
            emptyMessage={`No ${category.label.toLowerCase()} news yet. Check back soon.`}
          />
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
