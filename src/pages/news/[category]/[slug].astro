---
import { render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import CTA from '../../../components/CTA.astro';
import {
  NEWS_BASE_PATH,
  getNewsCategory,
  getNewsSlug,
  getPublishedNews,
  slugifyNewsTag,
} from '../../../data/news';

export async function getStaticPaths() {
  const entries = await getPublishedNews();
  return entries.map((entry) => ({
    params: {
      category: entry.data.category,
      slug: getNewsSlug(entry),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const category = getNewsCategory(entry.data.category);
const formattedDate = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'News', href: NEWS_BASE_PATH },
  ...(category ? [{ label: category.label, href: category.href }] : []),
  { label: entry.data.title },
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <article>
    <header class="bg-surface py-10 lg:py-14">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">
          <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
          {category && (
            <>
              <span aria-hidden="true">&bull;</span>
              <a href={category.href} class="transition-colors hover:text-primary">
                {category.label}
              </a>
            </>
          )}
        </div>

        <h1 class="mt-4 font-heading text-h1 font-bold uppercase leading-tight text-text">
          {entry.data.title}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-muted">
          {entry.data.description}
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-text-muted">
          <span>{entry.data.author}</span>
          {entry.data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <li>
                  <a
                    href={`/news/tag/${slugifyNewsTag(tag)}`}
                    class="rounded-md border border-border bg-background px-2.5 py-1 text-xs font-semibold text-text-muted transition-colors hover:border-primary/40 hover:text-primary"
                  >
                    #{tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </header>

    {entry.data.image && (
      <div class="mx-auto mt-8 max-w-4xl px-4 sm:px-6">
        <img
          src={entry.data.image}
          alt={entry.data.imageAlt || entry.data.title}
          class="aspect-[16/9] w-full rounded-lg border border-border object-cover shadow-sm"
        />
      </div>
    )}

    <section class="py-10 lg:py-14">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:uppercase prose-a:text-primary-light hover:prose-a:text-primary">
          <Content />
        </div>

        <div class="mt-10 border-t border-border pt-6">
          <a
            href={category?.href || NEWS_BASE_PATH}
            class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-primary-light"
          >
            <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Back to {category?.label || 'News'}
          </a>
        </div>
      </div>
    </section>
  </article>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
