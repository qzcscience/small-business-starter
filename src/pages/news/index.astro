---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';
import NewsList from '../../components/news/NewsList.astro';
import NewsSidebar from '../../components/news/NewsSidebar.astro';
import { getNewsTags, getPublishedNews, newsCategories } from '../../data/news';

const entries = await getPublishedNews();
const tags = getNewsTags(entries);
const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'News' }];
---

<BaseLayout
  title="News"
  description="Read the latest Wayeal company updates, customer stories, trade show news, and industry insights."
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <NewsSidebar tags={tags} />

        <div class="min-w-0 flex-1">
          <div class="mb-8 rounded-lg border border-border bg-background px-6 py-6 shadow-sm sm:px-8">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
              News Center
            </p>
            <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-text">
                  News
                </h1>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
                  Follow Wayeal company updates, customer success stories, exhibition activity,
                  and industry notes for helium leak testing applications.
                </p>
              </div>
              <p class="text-sm font-medium text-text-muted">
                {entries.length} Articles · {newsCategories.length} Categories
              </p>
            </div>
          </div>

          <NewsList entries={entries} />
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
