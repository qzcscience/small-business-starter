---
import AboutDetailShell from '../../components/about/AboutDetailShell.astro';
import { getAboutSection } from '../../data/about';

const section = getAboutSection('company-overview')!;
---

<AboutDetailShell
  section={section}
  showSummary={false}
  showHighlights={false}
  showBackLink={false}
  showCta={false}
>
  <div class="space-y-5">
    {section.blocks.map((block) => (
      <section aria-label={block.title}>
        <div class="space-y-5">
          {block.body.map((paragraph) => (
            <p class="text-base leading-8 text-text-muted sm:text-lg sm:leading-9">{paragraph}</p>
          ))}
        </div>
      </section>
    ))}
  </div>
</AboutDetailShell>
