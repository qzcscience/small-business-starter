---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import CTA from '../../components/CTA.astro';
import {
  RESOURCE_BASE_PATH,
  resourceRoutes,
  resources,
  type ResourceRoute,
} from '../../data/resources';

export function getStaticPaths() {
  return resourceRoutes.map((route) => ({
    params: { slug: route.slug.join('/') },
    props: { route },
  }));
}

interface Props {
  route: ResourceRoute;
}

const { route } = Astro.props;
const { node } = route;
const children = node.children || [];
const childCount = children.length;
const nestedCount = children.reduce((count, child) => count + (child.children?.length || 0), 0);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: RESOURCE_BASE_PATH },
  ...route.ancestors.map((ancestor, index) => ({
    label: ancestor.label,
    href: index === route.ancestors.length - 1 ? undefined : ancestor.href,
  })),
];
---

<BaseLayout
  title={`${node.label} Resources`}
  description={node.description}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Resources"
          rootHref={RESOURCE_BASE_PATH}
          categories={resources}
          activeHref={node.href}
          collapsible
        />

        <div class="min-w-0 flex-1">
          <div class="rounded-lg border border-border bg-background shadow-sm">
            <div class="border-b border-border bg-surface/60 px-6 py-6 sm:px-8 lg:px-10">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                Resource {route.isLeaf ? 'Topic' : 'Category'}
              </p>
              <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-text">
                    {node.label}
                  </h1>
                  <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
                    {node.description}
                  </p>
                </div>
                {!route.isLeaf && (
                  <p class="text-sm font-medium text-text-muted">
                    {childCount + nestedCount} Topic{childCount + nestedCount === 1 ? '' : 's'}
                  </p>
                )}
              </div>
            </div>

            {!route.isLeaf && (
              <div class="space-y-8 p-5 sm:p-6 lg:p-8">
                {children.map((item) => (
                  <section class="rounded-lg border border-border bg-background p-5">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <a
                          href={item.href}
                          class="font-heading text-h2 font-semibold uppercase leading-tight text-text transition-colors hover:text-primary"
                        >
                          {item.label}
                        </a>
                        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-text-muted sm:text-base">
                          {item.description}
                        </p>
                      </div>
                      {item.children && item.children.length > 0 && (
                        <span class="rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-semibold text-text-muted">
                          {item.children.length} Topic{item.children.length === 1 ? '' : 's'}
                        </span>
                      )}
                    </div>

                    {item.children && item.children.length > 0 && (
                      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
                        {item.children.map((child) => (
                          <article class="rounded-lg border border-border bg-surface/60 p-4">
                            <a
                              href={child.href}
                              class="font-heading text-h3 font-semibold leading-tight text-text transition-colors hover:text-primary"
                            >
                              {child.label}
                            </a>
                            <p class="mt-2 text-sm leading-relaxed text-text-muted">
                              {child.description}
                            </p>
                          </article>
                        ))}
                      </div>
                    )}
                  </section>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
