---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import CTA from '../../components/CTA.astro';
import LeakRateUnitConverter from '../../components/resources/LeakRateUnitConverter.astro';
import {
  RESOURCE_BASE_PATH,
  resourceRoutes,
  resources,
  type ResourceRoute,
} from '../../data/resources';

export function getStaticPaths() {
  return resourceRoutes.map((route) => ({
    params: { slug: route.slug.join('/') },
    props: { route },
  }));
}

interface Props {
  route: ResourceRoute;
}

const { route } = Astro.props;
const { node } = route;
const article = node.article;
const children = node.children || [];
const downloads = node.downloads || [];
const videos = node.videos || [];
const childCount = children.length;
const nestedCount = children.reduce((count, child) => count + (child.children?.length || 0), 0);
const isLeakRateUnitConverter = route.slug.join('/') === 'useful-tools/leak-rate-unit-converter';
const pageTitle = article ? node.label : `${node.label} Resources`;
const pageImage = article?.heroImage?.src;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: RESOURCE_BASE_PATH },
  ...route.ancestors.map((ancestor, index) => ({
    label: ancestor.label,
    href: index === route.ancestors.length - 1 ? undefined : ancestor.href,
  })),
];
---

<BaseLayout
  title={pageTitle}
  description={node.description}
  image={pageImage}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Resources"
          rootHref={RESOURCE_BASE_PATH}
          categories={resources}
          activeHref={node.href}
          collapsible
        />

        <div class="min-w-0 flex-1">
          <div class="rounded-lg border border-border bg-background shadow-sm">
            <div class="border-b border-border bg-surface/60 px-6 py-6 sm:px-8 lg:px-10">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                Resource {route.isLeaf ? 'Topic' : 'Category'}
              </p>
              <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-text">
                    {node.label}
                  </h1>
                  <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
                    {node.description}
                  </p>
                </div>
                {!route.isLeaf && (
                  <p class="text-sm font-medium text-text-muted">
                    {childCount + nestedCount} Topic{childCount + nestedCount === 1 ? '' : 's'}
                  </p>
                )}
                {route.isLeaf && downloads.length > 0 && (
                  <p class="text-sm font-medium text-text-muted">
                    {downloads.length} Document{downloads.length === 1 ? '' : 's'}
                  </p>
                )}
                {route.isLeaf && videos.length > 0 && (
                  <p class="text-sm font-medium text-text-muted">
                    {videos.length} Video{videos.length === 1 ? '' : 's'}
                  </p>
                )}
              </div>
            </div>

            {!route.isLeaf && (
              <div class="space-y-8 p-5 sm:p-6 lg:p-8">
                {children.map((item) => (
                  <section class="rounded-lg border border-border bg-background p-5">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <a
                          href={item.href}
                          class="font-heading text-h2 font-semibold uppercase leading-tight text-text transition-colors hover:text-primary"
                        >
                          {item.label}
                        </a>
                        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-text-muted sm:text-base">
                          {item.description}
                        </p>
                      </div>
                      {item.children && item.children.length > 0 && (
                        <span class="rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-semibold text-text-muted">
                          {item.children.length} Topic{item.children.length === 1 ? '' : 's'}
                        </span>
                      )}
                    </div>

                    {item.children && item.children.length > 0 && (
                      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
                        {item.children.map((child) => (
                          <article class="rounded-lg border border-border bg-surface/60 p-4">
                            <a
                              href={child.href}
                              class="font-heading text-h3 font-semibold leading-tight text-text transition-colors hover:text-primary"
                            >
                              {child.label}
                            </a>
                            <p class="mt-2 text-sm leading-relaxed text-text-muted">
                              {child.description}
                            </p>
                          </article>
                        ))}
                      </div>
                    )}
                  </section>
                ))}
              </div>
            )}

            {route.isLeaf && isLeakRateUnitConverter && <LeakRateUnitConverter />}

            {route.isLeaf && article && videos.length > 0 && (
              <section class="border-b border-border p-5 sm:p-6 lg:p-8">
                <div class="max-w-3xl">
                  <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">
                    Video Demonstration
                  </p>
                  <h2 class="mt-2 font-heading text-h2 font-semibold uppercase text-text">
                    See the Method in Action
                  </h2>
                </div>

                <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
                  {videos.map((video) => (
                    <article class="flex min-w-0 flex-col overflow-hidden rounded-lg border border-border bg-background shadow-sm">
                      <div
                        class:list={[
                          'relative bg-dark',
                          video.aspectRatio === 'short'
                            ? 'mx-auto aspect-[9/16] w-full max-w-[22rem]'
                            : 'aspect-video',
                        ]}
                      >
                        <iframe
                          src={video.embedUrl}
                          title={video.title}
                          loading="lazy"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                          referrerpolicy="strict-origin-when-cross-origin"
                          class="absolute inset-0 size-full border-0"
                        ></iframe>
                      </div>
                      <div class="flex flex-1 flex-col p-5">
                        <p class="text-xs font-semibold uppercase text-accent">
                          YouTube Video
                        </p>
                        <h3 class="mt-2 font-heading text-h3 font-semibold leading-tight text-text">
                          {video.title}
                        </h3>
                        <p class="mt-3 text-sm leading-relaxed text-text-muted">
                          {video.description}
                        </p>
                        <a
                          href={video.watchUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-4 text-sm font-semibold text-primary hover:underline"
                        >
                          Open on YouTube
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            )}

            {route.isLeaf && article && (
              <article class="p-5 sm:p-6 lg:p-8">
                {article.heroImage && (
                  <figure class="overflow-hidden rounded-lg border border-border bg-background shadow-sm">
                    <img
                      src={article.heroImage.src}
                      alt={article.heroImage.alt}
                      class="h-auto w-full object-contain"
                      loading="eager"
                    />
                    {article.heroImage.caption && (
                      <figcaption class="border-t border-border bg-surface px-4 py-3 text-sm leading-relaxed text-text-muted sm:px-5">
                        {article.heroImage.caption}
                      </figcaption>
                    )}
                  </figure>
                )}

                {article.quickFacts && article.quickFacts.length > 0 && (
                  <dl class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                    {article.quickFacts.map((fact) => (
                      <div class="rounded-md border border-border bg-surface p-4">
                        <dt class="text-xs font-semibold uppercase tracking-wider text-accent">
                          {fact.label}
                        </dt>
                        <dd class="mt-2 text-sm font-semibold leading-snug text-text">
                          {fact.value}
                        </dd>
                      </div>
                    ))}
                  </dl>
                )}

                {article.intro && article.intro.length > 0 && (
                  <div class="mt-8 max-w-4xl space-y-4">
                    {article.intro.map((paragraph) => (
                      <p class="text-base leading-relaxed text-text-muted sm:text-lg">
                        {paragraph}
                      </p>
                    ))}
                  </div>
                )}

                <div class="mt-10 space-y-10">
                  {article.sections.map((section) => (
                    <section class="border-t border-border pt-8 first:border-t-0 first:pt-0">
                      {section.eyebrow && (
                        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">
                          {section.eyebrow}
                        </p>
                      )}
                      <h2 class="mt-2 font-heading text-h2 font-semibold uppercase text-text">
                        {section.title}
                      </h2>

                      {section.paragraphs && section.paragraphs.length > 0 && (
                        <div class="mt-5 max-w-4xl space-y-4">
                          {section.paragraphs.map((paragraph) => (
                            <p class="text-base leading-relaxed text-text-muted">
                              {paragraph}
                            </p>
                          ))}
                        </div>
                      )}

                      {section.steps && section.steps.length > 0 && (
                        <ol class="mt-6 grid gap-4">
                          {section.steps.map((step, index) => (
                            <li class="rounded-md border border-border bg-background p-5 shadow-sm sm:flex sm:gap-5">
                              <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-fg">
                                {index + 1}
                              </div>
                              <div class="mt-4 min-w-0 sm:mt-0">
                                <h3 class="font-heading text-xl font-semibold uppercase text-text">
                                  {step.title}
                                </h3>
                                <p class="mt-2 text-sm leading-relaxed text-text-muted sm:text-base">
                                  {step.description}
                                </p>
                              </div>
                            </li>
                          ))}
                        </ol>
                      )}

                      {section.bullets && section.bullets.length > 0 && (
                        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
                          {section.bullets.map((bullet) => (
                            <li class="flex gap-3 rounded-md border border-border bg-surface p-4 text-sm leading-relaxed text-text-muted">
                              <span class="mt-1.5 size-2 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                              <span>{bullet}</span>
                            </li>
                          ))}
                        </ul>
                      )}

                      {section.cards && section.cards.length > 0 && (
                        <div class="mt-6 grid gap-4 md:grid-cols-2">
                          {section.cards.map((card) => (
                            <article class="rounded-md border border-border bg-background p-5 shadow-sm">
                              <h3 class="font-heading text-xl font-semibold uppercase text-text">
                                {card.title}
                              </h3>
                              <p class="mt-3 text-sm leading-relaxed text-text-muted sm:text-base">
                                {card.description}
                              </p>
                            </article>
                          ))}
                        </div>
                      )}

                      {section.callout && (
                        <aside class="mt-6 rounded-md border border-primary/20 bg-primary/5 p-5">
                          <h3 class="font-heading text-xl font-semibold uppercase text-text">
                            {section.callout.title}
                          </h3>
                          <p class="mt-3 text-sm leading-relaxed text-text-muted sm:text-base">
                            {section.callout.text}
                          </p>
                          {section.callout.bullets && section.callout.bullets.length > 0 && (
                            <ul class="mt-4 grid gap-2">
                              {section.callout.bullets.map((bullet) => (
                                <li class="flex gap-2 text-sm leading-relaxed text-text-muted">
                                  <span class="mt-2 size-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                                  <span>{bullet}</span>
                                </li>
                              ))}
                            </ul>
                          )}
                        </aside>
                      )}
                    </section>
                  ))}
                </div>

                {article.cta && (
                  <div class="mt-10 rounded-lg bg-primary px-5 py-7 text-primary-fg sm:px-7">
                    <h2 class="font-heading text-h2 font-semibold uppercase text-primary-fg">
                      {article.cta.title}
                    </h2>
                    <p class="mt-3 max-w-3xl text-base leading-relaxed text-primary-fg/85">
                      {article.cta.description}
                    </p>
                    <a
                      href={article.cta.href}
                      class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
                    >
                      {article.cta.label}
                    </a>
                  </div>
                )}
              </article>
            )}

            {route.isLeaf && downloads.length > 0 && (
              <div class="p-5 sm:p-6 lg:p-8">
                <div class="space-y-4">
                  {downloads.map((download) => (
                    <article class="flex min-w-0 flex-col gap-4 rounded-lg border border-border bg-background p-5 shadow-sm sm:flex-row sm:items-center sm:justify-between">
                      <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row sm:items-center">
                        <div class="shrink-0">
                          <p class="inline-flex rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-semibold uppercase text-accent">
                            {download.standard}
                          </p>
                        </div>
                        <div class="min-w-0">
                          <h2 class="font-heading text-h3 font-semibold leading-tight text-text">
                            {download.title}
                          </h2>
                          <p class="mt-2 break-words text-sm leading-relaxed text-text-muted">
                            {download.fileName}
                          </p>
                        </div>
                      </div>
                      <div class="flex shrink-0 items-center gap-3 sm:justify-end">
                        <span class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-semibold text-text-muted">
                          {download.extension}
                        </span>
                        <a
                          href={download.href}
                          download
                          class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-fg transition-colors hover:bg-primary-light"
                        >
                          Download PDF
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )}

            {route.isLeaf && !article && videos.length > 0 && (
              <div class="p-5 sm:p-6 lg:p-8">
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                  {videos.map((video) => (
                    <article class="flex min-w-0 flex-col overflow-hidden rounded-lg border border-border bg-background shadow-sm">
                      <div
                        class:list={[
                          'relative bg-dark',
                          video.aspectRatio === 'short'
                            ? 'mx-auto aspect-[9/16] w-full max-w-[22rem]'
                            : 'aspect-video',
                        ]}
                      >
                        <iframe
                          src={video.embedUrl}
                          title={video.title}
                          loading="lazy"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                          referrerpolicy="strict-origin-when-cross-origin"
                          class="absolute inset-0 size-full border-0"
                        ></iframe>
                      </div>
                      <div class="flex flex-1 flex-col p-5">
                        <p class="text-xs font-semibold uppercase text-accent">
                          YouTube Video
                        </p>
                        <h2 class="mt-2 font-heading text-h3 font-semibold leading-tight text-text">
                          {video.title}
                        </h2>
                        <p class="mt-3 text-sm leading-relaxed text-text-muted">
                          {video.description}
                        </p>
                        <a
                          href={video.watchUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-4 text-sm font-semibold text-primary hover:underline"
                        >
                          Open on YouTube
                        </a>
                        {video.relatedLinks.length > 0 && (
                          <div class="mt-5 border-t border-border pt-4">
                            <p class="text-xs font-semibold uppercase text-text-muted">
                              Related pages
                            </p>
                            <ul class="mt-3 flex flex-wrap gap-2">
                              {video.relatedLinks.map((link) => (
                                <li>
                                  {link.href ? (
                                    <a
                                      href={link.href}
                                      class="inline-flex rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-text-muted transition-colors hover:border-primary hover:text-primary"
                                    >
                                      {link.label}
                                    </a>
                                  ) : (
                                    <span class="inline-flex rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-text-muted">
                                      {link.label}
                                    </span>
                                  )}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
