---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import CTA from '../../components/CTA.astro';
import { RESOURCE_BASE_PATH, resources } from '../../data/resources';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources' },
];

const itemCount = resources.reduce((count, category) => {
  const children = category.children || [];
  const nested = children.reduce((childCount, child) => childCount + (child.children?.length || 0), 0);
  return count + children.length + nested;
}, 0);
---

<BaseLayout
  title="Resources"
  description="Browse Wayeal leak testing glossary entries, technical guides, case studies, downloads, videos, and useful tools."
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Resources"
          rootHref={RESOURCE_BASE_PATH}
          categories={resources}
          collapsible
        />

        <div class="min-w-0 flex-1">
          <div class="rounded-lg border border-border bg-background shadow-sm">
            <div class="border-b border-border bg-surface/60 px-6 py-6 sm:px-8 lg:px-10">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                Resource Center
              </p>
              <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-text">
                    Resources
                  </h1>
                  <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
                    Find leak testing definitions, engineering guides, application notes, product documents,
                    videos, and practical tools for method selection.
                  </p>
                </div>
                <p class="text-sm font-medium text-text-muted">
                  {resources.length} Categories · {itemCount} Topics
                </p>
              </div>
            </div>

            <div class="p-5 sm:p-6 lg:p-8">
              <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {resources.map((category) => (
                  <article class="group h-full">
                    <a
                      href={category.href}
                      class="flex h-full flex-col rounded-lg border border-border bg-background p-5 transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg"
                    >
                      <div class="flex items-start justify-between gap-4">
                        <h2 class="font-heading text-h3 font-semibold uppercase leading-tight text-text">
                          {category.label}
                        </h2>
                        <span class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-semibold text-text-muted">
                          {category.children?.length || 0}
                        </span>
                      </div>
                      <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
                        {category.description}
                      </p>
                      <span class="mt-5 text-sm font-semibold text-primary transition-colors group-hover:text-primary-light">
                        Open category
                      </span>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
