---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import CompanyVideo from '../components/CompanyVideo.astro';
import About from '../components/About.astro';
import Gallery from '../components/Gallery.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import {
  createFAQPageSchema,
  createOrganizationSchema,
  createWebSiteSchema,
} from '../utils/seo';

const homepageFaqItems = [
  {
    question: 'What information should I provide for a recommendation?',
    answer:
      'Share your part size, material, sealing structure, target leak rate, cycle time, production volume, automation requirements, and preferred helium handling method. These details help Wayeal recommend the right helium leak testing system for your workflow.',
  },
  {
    question: 'Can Wayeal support customized fixtures or chamber systems?',
    answer:
      'Yes. Wayeal supports customized fixtures, vacuum chamber leak detection systems, helium recovery configurations, and production-line integration for parts that require repeatable industrial leak testing.',
  },
  {
    question: 'Do you support commissioning and operator training?',
    answer:
      'Yes. Wayeal can support equipment commissioning, method setup, operator training, spare parts, and long-term technical support so the helium leak detection process runs reliably in production.',
  },
];
---

<BaseLayout
  title="Helium Leak Detection Systems Manufacturer"
  description="Wayeal manufactures helium leak detectors, vacuum chamber systems, helium recovery systems, and production-line leak testing solutions."
  schema={[
    createOrganizationSchema(),
    createWebSiteSchema(),
    createFAQPageSchema(homepageFaqItems),
  ]}
>
  <Header slot="header" />

  <Hero />
  <TrustBar />
  <CompanyVideo />
  <About />
  <Gallery />
  <FAQ items={homepageFaqItems} />
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
