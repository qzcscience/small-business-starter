---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import ProductGallery from '../../components/atoms/ProductGallery.astro';
import ProductInfo from '../../components/molecules/ProductInfo.astro';
import ProductTabs from '../../components/molecules/ProductTabs.astro';
import { products } from '../../data/products';
import { navItems } from '../../config/nav';

const product = products['helium-leak-detector'];
const productOverview = product.overview || product.description;
const productBenefits = product.benefits || [];
const productSpecSections = product.specSections || [
  {
    title: 'Specifications',
    specs: product.specs,
  },
];

const productLinks = navItems.find(item => item.label === 'Products')?.children?.map(child => ({
  label: child.label,
  href: child.href || '#',
  children: child.children,
})) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: product.title },
];
---

<BaseLayout title={product.title} description={product.description}>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">

        <!-- Left Sidebar - Category Navigation -->
        <CategorySidebar
          title="Products"
          categories={productLinks}
          activeSlug="helium-leak-detector"
        />

        <!-- Main Content -->
        <div class="flex-1 min-w-0">

          <!-- Product Header: Gallery + Info -->
          <div class="flex gap-6 mb-8 flex-col md:flex-row">

            <!-- Product Gallery -->
            <div class="w-full md:w-[45%]">
              <ProductGallery images={product.images} videoSrc={product.videoSrc} />
            </div>

            <!-- Product Info -->
            <div class="w-full md:w-[51.5%]">
              <ProductInfo
                title={product.title}
                specs={product.specs}
                ctaLabel={product.ctaLabel}
                ctaHref={product.ctaHref}
                description={product.description}
              />
            </div>
          </div>

          <!-- Product Tabs -->
          <div class="bg-white rounded-lg shadow-sm p-6">
            <ProductTabs tabs={[
              { id: 'overview', label: 'Product Description' },
              { id: 'specs', label: 'Spec' },
              { id: 'applications', label: 'Application' },
              { id: 'downloads', label: 'Downloads' },
            ]}>

              <!-- Overview Tab -->
              <div id="overview" class="tab-content">
                <h2 class="text-2xl font-bold text-text mb-4">Product Overview</h2>
                <div class="w-[62px] h-[5px] bg-primary mb-6"></div>
                <div class="space-y-6 text-text-muted">
                  <p class="text-lg leading-relaxed">{productOverview}</p>

                  {productBenefits.length > 0 && (
                    <div>
                      <h3 class="mb-3 font-heading text-xl font-semibold text-text">
                        Benefits at a Glance
                      </h3>
                      <ul class="grid gap-3 sm:grid-cols-2">
                        {productBenefits.map((benefit) => (
                          <li class="flex gap-3 rounded-md border border-border bg-surface p-4 text-sm leading-relaxed text-text-muted">
                            <span class="mt-1 size-2 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                            <span>{benefit}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              </div>

              <!-- Specs Tab -->
              <div id="specs" class="tab-content">
                <h2 class="text-2xl font-bold text-text mb-4">Specifications</h2>
                <div class="w-[62px] h-[5px] bg-primary mb-6"></div>
                <div class="space-y-8">
                  {productSpecSections.map((section) => (
                    <section>
                      <h3 class="mb-3 font-heading text-xl font-semibold text-text">
                        {section.title}
                      </h3>
                      <div class="overflow-x-auto">
                        <table class="w-full min-w-[520px] border border-border text-sm sm:text-base">
                          <tbody>
                            {section.specs.map((spec) => (
                              <tr class="border-b border-border last:border-b-0">
                                <th scope="row" class="w-[42%] border-r border-border bg-surface p-3 text-left font-medium text-gray-800">
                                  {spec.label}
                                </th>
                                <td class="p-3 text-text-muted">
                                  {spec.value}
                                </td>
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </section>
                  ))}
                </div>
              </div>

              <!-- Applications Tab -->
              <div id="applications" class="tab-content">
                <h2 class="text-2xl font-bold text-text mb-4">Applications</h2>
                <div class="w-[62px] h-[5px] bg-primary mb-6"></div>
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                  {product.applications.map((app) => (
                    <article class="flex h-full flex-col rounded-lg border border-border bg-background p-5 shadow-sm">
                      <h3 class="font-heading text-xl font-semibold text-text">
                        {app.name}
                      </h3>
                      {app.description && (
                        <p class="mt-3 text-sm leading-relaxed text-text-muted">
                          {app.description}
                        </p>
                      )}
                      {app.workpieces && app.workpieces.length > 0 && (
                        <div class="mt-4">
                          <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">
                            Typical workpieces
                          </p>
                          <ul class="mt-3 flex flex-wrap gap-2">
                            {app.workpieces.map((workpiece) => (
                              <li class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-text-muted">
                                {workpiece}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                      {app.href && (
                        <a href={app.href} class="mt-5 text-sm font-semibold text-primary hover:underline">
                          View related solution
                        </a>
                      )}
                    </article>
                  ))}
                </div>
              </div>

              <!-- Downloads Tab -->
              <div id="downloads" class="tab-content">
                <h2 class="text-2xl font-bold text-text mb-4">Downloads</h2>
                <div class="w-[62px] h-[5px] bg-primary mb-6"></div>
                {product.downloads.length > 0 ? (
                  <div class="grid gap-3">
                    {product.downloads.map((download) => (
                      <a
                        href={download.href}
                        download
                        class="group flex min-w-0 items-center justify-between gap-4 rounded-md border border-border bg-background px-4 py-3 transition-colors hover:border-primary hover:bg-surface"
                      >
                        <div class="min-w-0">
                          <div class="truncate font-medium text-text group-hover:text-primary">
                            {download.label}
                          </div>
                          <div class="mt-1 text-sm text-text-muted">
                            {download.fileName}
                          </div>
                        </div>
                        <span class="shrink-0 rounded-md border border-border px-2.5 py-1 text-xs font-semibold text-text-muted">
                          {download.extension}
                        </span>
                      </a>
                    ))}
                  </div>
                ) : (
                  <p class="text-text-muted">No downloads available yet.</p>
                )}
              </div>

            </ProductTabs>
          </div>

        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @media (max-width: 1024px) {
    /* Tablet and mobile adjustments */
  }

  @media (max-width: 768px) {
    /* Mobile adjustments */
  }
</style>
