---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../../../components/atoms/CategorySidebar.astro';
import CTA from '../../../../components/CTA.astro';
import { navItems } from '../../../../config/nav';
import {
  VACUUM_CHAMBER_BASE_PATH,
  vacuumChamberSkus,
  type VacuumChamberSkuWithContext,
} from '../../../../data/vacuumChamber';

export function getStaticPaths() {
  return vacuumChamberSkus.map((sku) => ({
    params: { applicationSlug: sku.applicationSlug, skuSlug: sku.slug },
    props: { sku },
  }));
}

interface Props {
  sku: VacuumChamberSkuWithContext;
}

const { sku } = Astro.props;
const applicationHref = `${VACUUM_CHAMBER_BASE_PATH}/${sku.applicationSlug}`;

const productLinks =
  navItems
    .find((item) => item.label === 'Products')
    ?.children?.map((child) => ({
      label: child.label,
      href: child.href || '#',
      children: child.children,
    })) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Vacuum Chamber Leak Detection System', href: VACUUM_CHAMBER_BASE_PATH },
  { label: sku.applicationLabel, href: applicationHref },
  { label: sku.name },
];
---

<BaseLayout title={sku.name} description={sku.description} image={sku.image}>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Product Categories"
          eyebrow="Navigation"
          categories={productLinks}
          activeHref={applicationHref}
        />

        <div class="min-w-0 flex-1">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start">
            <div class="overflow-hidden rounded-lg border border-border bg-surface">
              <div class="flex aspect-[4/3] items-center justify-center p-8">
                <img src={sku.image} alt={sku.name} class="h-full w-full object-contain" />
              </div>
            </div>

            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">
                {sku.sku}
              </p>
              <h1 class="mt-3 font-heading text-h1 font-bold uppercase leading-tight text-text">
                {sku.name}
              </h1>
              <p class="mt-4 text-lg leading-relaxed text-text-muted">
                {sku.description}
              </p>

              <div class="mt-6 flex flex-wrap gap-2 text-sm font-medium">
                <a
                  href={applicationHref}
                  class="rounded-md border border-border bg-background px-3 py-2 text-text-muted transition-colors hover:border-primary hover:text-primary"
                >
                  {sku.applicationLabel}
                </a>
                <span class="rounded-md border border-border bg-background px-3 py-2 text-text-muted">
                  {sku.equipmentLabel}
                </span>
              </div>

              <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                <a
                  href="/contact"
                  class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
                >
                  Request Quote
                </a>
                <a
                  href={applicationHref}
                  class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-border px-6 py-3 text-sm font-bold text-text transition-colors hover:border-primary hover:text-primary"
                >
                  Back to Application
                </a>
              </div>
            </div>
          </div>

          <section class="mt-10 bg-surface px-5 py-8 sm:px-6 lg:px-8">
            <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
              <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                  SKU Details
                </p>
                <h2 class="mt-2 font-heading text-h2 font-semibold uppercase text-text">
                  Key Configuration
                </h2>
                <p class="mt-3 leading-relaxed text-text-muted">
                  Use these details as a starting point. Chamber dimensions, tooling, pumping
                  speed, and automation level can be configured around the actual component and
                  cycle time.
                </p>
              </div>

              <div class="overflow-hidden rounded-lg border border-border bg-background">
                <table class="w-full border-collapse text-left text-sm">
                  <tbody>
                    {sku.specs.map((spec) => (
                      <tr class="border-b border-border last:border-b-0">
                        <th class="w-1/3 bg-surface px-4 py-3 font-semibold text-text">
                          {spec.label}
                        </th>
                        <td class="px-4 py-3 text-text-muted">
                          {spec.value}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Confirm This SKU For Your Part"
    description="Send us your part dimensions, target leak rate, fixture needs, and expected throughput. We will recommend the best chamber configuration."
    buttonText="Contact Engineering"
    buttonHref="/contact"
  />

  <Footer slot="footer" />
</BaseLayout>
