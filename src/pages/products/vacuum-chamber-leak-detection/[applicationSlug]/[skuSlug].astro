---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../../../components/atoms/CategorySidebar.astro';
import ProductGallery from '../../../../components/atoms/ProductGallery.astro';
import CTA from '../../../../components/CTA.astro';
import sfz344WorkflowDiagramSvg from '../../../../assets/images/products/vacuum-chamber/sfz-344-car-ac-condenser/system-workflow-mermaid.svg?raw';
import { brand } from '../../../../config/brand';
import { navItems } from '../../../../config/nav';
import {
  VACUUM_CHAMBER_BASE_PATH,
  vacuumChamberSkus,
  type VacuumChamberSkuWithContext,
} from '../../../../data/vacuumChamber';

export function getStaticPaths() {
  return vacuumChamberSkus.map((sku) => ({
    params: { applicationSlug: sku.applicationSlug, skuSlug: sku.slug },
    props: { sku },
  }));
}

interface Props {
  sku: VacuumChamberSkuWithContext;
}

const { sku } = Astro.props;
const applicationHref = `${VACUUM_CHAMBER_BASE_PATH}/${sku.applicationSlug}`;
const skuImages = sku.images?.length ? sku.images : [{ src: sku.image, alt: sku.name }];
const primaryImage = skuImages[0]?.src || sku.image;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? brand.url).toString();
const imageUrl = new URL(primaryImage, Astro.site ?? brand.url).toString();
const sourceContent = sku.sourceContent;
const workflowDiagram = sourceContent?.workflowDiagram;
const workflowDiagramMarkup = sku.slug === 'sfz-344-car-ac-condenser' ? sfz344WorkflowDiagramSvg : undefined;
const specSections = sku.specSections?.length
  ? sku.specSections
  : [
      {
        title: 'Key Configuration',
        specs: sku.specs,
      },
    ];

const productLinks =
  navItems
    .find((item) => item.label === 'Products')
    ?.children?.map((child) => ({
      label: child.label,
      href: child.href || '#',
      children: child.children,
    })) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Vacuum Chamber Leak Detection System', href: VACUUM_CHAMBER_BASE_PATH },
  { label: sku.applicationLabel, href: applicationHref },
  { label: sku.name },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: sku.name,
  sku: sku.sku,
  brand: {
    '@type': 'Brand',
    name: brand.name,
  },
  category: `${sku.applicationLabel} ${sku.equipmentLabel}`,
  description: sku.description,
  image: imageUrl,
  url: pageUrl,
};

const ctaTitle =
  sku.slug === 'sfz-344-car-ac-condenser'
    ? 'Configure SFZ-344 For Your Condenser'
    : 'Confirm This SKU For Your Part';
const ctaDescription =
  sku.slug === 'sfz-344-car-ac-condenser'
    ? 'Send us your condenser dimensions, port layout, target leak rate, takt time, and automation needs. We will match the chamber, pump set, fixture, and helium recovery design to your process.'
    : 'Send us your part dimensions, target leak rate, fixture needs, and expected throughput. We will recommend the best chamber configuration.';
---

<BaseLayout title={sku.name} description={sku.description} image={primaryImage} schema={schema}>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Products"
          categories={productLinks}
          activeHref={applicationHref}
        />

        <div class="min-w-0 flex-1">
          <div class="space-y-6">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
              <ProductGallery images={skuImages} videoSrc={sku.videoSrc} />

              <div class="min-w-0 lg:flex lg:self-stretch lg:flex-col lg:justify-center">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">
                  {sku.sku}
                </p>
                <h1 class="mt-3 font-heading text-h2 font-bold uppercase leading-tight text-text">
                  {sku.name}
                </h1>
                <p class="mt-4 text-lg leading-relaxed text-text-muted">
                  {sku.description}
                </p>
              </div>
            </div>

            <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex flex-wrap gap-2 text-sm font-medium">
                <a
                  href={applicationHref}
                  class="rounded-md border border-border bg-background px-3 py-2 text-text-muted transition-colors hover:border-primary hover:text-primary"
                >
                  {sku.applicationLabel}
                </a>
                <span class="rounded-md border border-border bg-background px-3 py-2 text-text-muted">
                  {sku.equipmentLabel}
                </span>
              </div>

              <div class="flex flex-col gap-3 sm:flex-row">
                <a
                  href="/contact"
                  class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
                >
                  Request Quote
                </a>
                <a
                  href={applicationHref}
                  class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-border px-6 py-3 text-sm font-bold text-text transition-colors hover:border-primary hover:text-primary"
                >
                  Back to Application
                </a>
              </div>
            </div>
          </div>

          {sourceContent ? (
            <>
              <section class="mt-10 bg-surface px-5 py-8 sm:px-6 lg:px-8">
                <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                  I Main Technical Specs
                </h2>

                <dl class="mt-6 overflow-hidden rounded-lg border border-border bg-background">
                  {sourceContent.technicalSpecs.map((spec) =>
                    spec.children?.length ? (
                      <>
                        <div class="grid gap-1 border-b border-border bg-surface px-4 py-3 sm:grid-cols-[minmax(180px,0.42fr)_1fr] sm:gap-6 sm:px-5">
                          <dt class="text-sm font-semibold text-text">
                            {spec.label}
                          </dt>
                          <dd aria-hidden="true"></dd>
                        </div>
                        {spec.children.map((child) => (
                          <div class="grid gap-1 border-b border-border px-4 py-3 last:border-b-0 sm:grid-cols-[minmax(180px,0.42fr)_1fr] sm:gap-6 sm:px-5">
                            <dt class="pl-4 text-sm font-semibold text-text sm:pl-8">
                              {child.label}
                            </dt>
                            <dd class="text-sm leading-relaxed text-text-muted">
                              {child.value}
                            </dd>
                          </div>
                        ))}
                      </>
                    ) : (
                      <div class="grid gap-1 border-b border-border px-4 py-3 last:border-b-0 sm:grid-cols-[minmax(180px,0.42fr)_1fr] sm:gap-6 sm:px-5">
                        <dt class="text-sm font-semibold text-text">
                          {spec.label}
                        </dt>
                        <dd class="text-sm leading-relaxed text-text-muted">
                          {spec.value}
                        </dd>
                      </div>
                    )
                  )}
                </dl>
              </section>

              <section class="mt-10">
                <div class="max-w-3xl">
                  <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                    II System Working Principle
                  </h2>
                </div>

                <figure class="mt-6 overflow-hidden rounded-lg border border-border bg-background">
                  <img
                    src={sourceContent.principleImage.src}
                    alt={sourceContent.principleImage.alt}
                    class="h-auto w-full object-contain"
                    loading="lazy"
                  />
                </figure>

                <div class="mt-6 space-y-4">
                  {sourceContent.workingPrinciple.map((principle, index) => (
                    <article class="rounded-md border border-border bg-background p-5 sm:flex sm:gap-5">
                      <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-fg">
                        {index + 1}
                      </div>
                      <div class="mt-4 min-w-0 sm:mt-0">
                        <h3 class="font-heading text-xl font-semibold uppercase text-text">
                          {principle.title}
                        </h3>
                        <div class="mt-3 space-y-3">
                          {principle.paragraphs.map((paragraph) => (
                            <p class="text-sm leading-relaxed text-text-muted">
                              {paragraph}
                            </p>
                          ))}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </section>

              <section class="mt-10 bg-surface px-5 py-8 sm:px-6 lg:px-8">
                <div class="max-w-3xl">
                  <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                    III System Workflow
                  </h2>
                </div>

                {workflowDiagramMarkup ? (
                  <figure class="mt-6 overflow-hidden rounded-lg border border-border bg-background">
                    <div class="workflow-diagram overflow-x-auto p-4 sm:p-6" set:html={workflowDiagramMarkup} />
                  </figure>
                ) : workflowDiagram?.src ? (
                  <figure class="mt-6 overflow-hidden rounded-lg border border-border bg-background">
                    <div class="overflow-x-auto p-4 sm:p-6">
                      <img
                        src={workflowDiagram.src}
                        alt={workflowDiagram.alt}
                        class="mx-auto h-auto w-[584px] max-w-none"
                        loading="lazy"
                      />
                    </div>
                  </figure>
                ) : (
                  <p class="mt-6 rounded-md border border-border bg-background px-4 py-3 text-sm font-semibold text-text-muted">
                    Workflow diagram asset is not configured.
                  </p>
                )}
              </section>

              <section class="mt-10">
                <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                  IV Main Optional Configurations
                </h2>

                <div class="mt-6 overflow-x-auto rounded-lg border border-border bg-background">
                  <table class="w-full min-w-[640px] border-collapse text-left text-sm">
                    <thead>
                      <tr class="border-b border-border bg-surface">
                        <th class="w-[38%] px-4 py-3 font-semibold text-text">
                          Components
                        </th>
                        <th class="px-4 py-3 font-semibold text-text">
                          Brand Options
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {sourceContent.optionalConfigurations.map((config) => (
                        <tr class="border-b border-border last:border-b-0">
                          <th class="px-4 py-3 font-semibold text-text">
                            {config.label}
                          </th>
                          <td class="px-4 py-3 leading-relaxed text-text-muted">
                            {config.value}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            </>
          ) : (
            <section class="mt-10 bg-surface px-5 py-8 sm:px-6 lg:px-8">
              <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                    SKU Details
                  </p>
                  <h2 class="mt-2 font-heading text-h2 font-semibold uppercase text-text">
                    Key Configuration
                  </h2>
                  <p class="mt-3 leading-relaxed text-text-muted">
                    Use these details as a starting point. Chamber dimensions, tooling, pumping
                    speed, and automation level can be configured around the actual component and
                    cycle time.
                  </p>
                </div>

                <div class="space-y-6">
                  {specSections.map((section) => (
                    <section>
                      <h3 class="mb-3 font-heading text-xl font-semibold uppercase text-text">
                        {section.title}
                      </h3>
                      <div class="overflow-hidden rounded-lg border border-border bg-background">
                        <table class="w-full border-collapse text-left text-sm">
                          <tbody>
                            {section.specs.map((spec) => (
                              <tr class="border-b border-border last:border-b-0">
                                <th class="w-1/3 bg-surface px-4 py-3 font-semibold text-text">
                                  {spec.label}
                                </th>
                                <td class="px-4 py-3 leading-relaxed text-text-muted">
                                  {spec.value}
                                </td>
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </section>
                  ))}
                </div>
              </div>
            </section>
          )}
        </div>
      </div>
    </div>
  </section>

  <CTA
    title={ctaTitle}
    description={ctaDescription}
    buttonText="Contact Engineering"
    buttonHref="/contact"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .workflow-diagram :global(svg) {
    display: block;
    width: 584px;
    max-width: none;
    height: auto;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .workflow-diagram :global(svg) {
      max-width: 100%;
    }
  }
</style>
