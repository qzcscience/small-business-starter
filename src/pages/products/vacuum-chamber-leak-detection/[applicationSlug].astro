---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../../components/atoms/CategorySidebar.astro';
import CTA from '../../../components/CTA.astro';
import { navItems } from '../../../config/nav';
import {
  VACUUM_CHAMBER_BASE_PATH,
  vacuumChamberApplications,
  type VacuumChamberApplication,
} from '../../../data/vacuumChamber';

export function getStaticPaths() {
  return vacuumChamberApplications.map((application) => ({
    params: { applicationSlug: application.slug },
    props: { application },
  }));
}

interface Props {
  application: VacuumChamberApplication;
}

const { application } = Astro.props;
const applicationHref = `${VACUUM_CHAMBER_BASE_PATH}/${application.slug}`;

const productLinks =
  navItems
    .find((item) => item.label === 'Products')
    ?.children?.map((child) => ({
      label: child.label,
      href: child.href || '#',
      children: child.children,
    })) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Vacuum Chamber Leak Detection System', href: VACUUM_CHAMBER_BASE_PATH },
  { label: application.label },
];

const skuCount = application.groups.reduce((count, group) => count + group.skus.length, 0);
---

<BaseLayout title={application.title} description={application.description}>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Product Categories"
          eyebrow="Navigation"
          categories={productLinks}
          activeHref={applicationHref}
        />

        <div class="min-w-0 flex-1">
          <div class="border-b border-border bg-surface px-6 py-8 sm:px-8 lg:px-10">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
              {application.eyebrow}
            </p>
            <h1 class="mt-3 font-heading text-h1 font-bold uppercase leading-tight text-text">
              {application.title}
            </h1>
            <p class="mt-4 max-w-3xl text-lg leading-relaxed text-text-muted">
              {application.description}
            </p>
            <div class="mt-6 flex flex-wrap gap-2 text-sm font-medium text-text-muted">
              <span class="rounded-md border border-border bg-background px-3 py-2">
                {application.groups.length} Equipment Type{application.groups.length === 1 ? '' : 's'}
              </span>
              <span class="rounded-md border border-border bg-background px-3 py-2">
                {skuCount} SKU{skuCount === 1 ? '' : 's'}
              </span>
            </div>
          </div>

          <div class="py-8 sm:py-10">
            <div class="mb-8 flex flex-wrap gap-2">
              {application.groups.map((group) => (
                <a
                  href={`#${group.slug}`}
                  class="rounded-md border border-border bg-background px-4 py-2 text-sm font-semibold text-text-muted transition-colors hover:border-primary hover:text-primary"
                >
                  {group.label}
                </a>
              ))}
            </div>

            <div class="space-y-12">
              {application.groups.map((group) => (
                <section id={group.slug} class="scroll-mt-28">
                  <div class="mb-5 max-w-3xl">
                    <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                      {group.label}
                    </h2>
                    <p class="mt-2 leading-relaxed text-text-muted">
                      {group.summary}
                    </p>
                  </div>

                  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                    {group.skus.map((sku) => (
                      <article class="group h-full overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-md">
                        <a href={`${applicationHref}/${sku.slug}`} class="flex h-full flex-col">
                          <div class="flex aspect-[4/3] items-center justify-center bg-surface p-6">
                            <img
                              src={sku.image}
                              alt={sku.name}
                              class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
                              loading="lazy"
                            />
                          </div>
                          <div class="flex flex-1 flex-col border-t border-border p-5">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
                              {sku.sku}
                            </p>
                            <h3 class="mt-2 font-heading text-xl font-semibold leading-snug text-text">
                              {sku.name}
                            </h3>
                            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
                              {sku.shortDescription}
                            </p>
                            <p class="mt-4 text-xs font-semibold uppercase tracking-[0.16em] text-text-muted">
                              {group.label}
                            </p>
                            <span class="mt-4 inline-flex min-h-[40px] items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-fg transition-opacity group-hover:opacity-90">
                              View Details
                            </span>
                          </div>
                        </a>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Need a Custom Leak Detection System?"
    description="Share your component size, target leak rate, and production workflow. We can help match the right chamber configuration."
    buttonText="Request a Solution"
    buttonHref="/contact"
  />

  <Footer slot="footer" />
</BaseLayout>
