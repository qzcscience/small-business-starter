---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../../components/atoms/CategorySidebar.astro';
import CTA from '../../../components/CTA.astro';
import { navItems } from '../../../config/nav';
import { accessories, accessoryGroups } from '../../../data/accessories';

const productLinks =
  navItems
    .find((item) => item.label === 'Products')
    ?.children?.map((child) => ({
      label: child.label,
      href: child.href || '#',
      children: child.children,
    })) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Accessories' },
];
---

<BaseLayout
  title="Accessories"
  description="Browse accessories and consumables for helium leak detection systems."
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Products"
          categories={productLinks}
          activeHref="/products/accessories"
        />

        <div class="min-w-0 flex-1">
          <div class="border-b border-border bg-surface px-6 py-8 sm:px-8 lg:px-10">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
              Product Line
            </p>
            <h1 class="mt-3 font-heading text-h1 font-bold uppercase leading-tight text-text">
              Accessories
            </h1>
            <p class="mt-4 max-w-3xl text-lg leading-relaxed text-text-muted">
              Accessories, consumables, probes, chambers, tooling, gauges, and replacement parts
              for helium leak detection systems.
            </p>
            <div class="mt-6 flex flex-wrap gap-2 text-sm font-medium text-text-muted">
              <span class="rounded-md border border-border bg-background px-3 py-2">
                {accessoryGroups.length} Equipment Type
              </span>
              <span class="rounded-md border border-border bg-background px-3 py-2">
                {accessories.length} SKUs
              </span>
            </div>
          </div>

          <div class="py-8 sm:py-10">
            <div class="mb-8 flex flex-wrap gap-2">
              {accessoryGroups.map((group) => (
                <a
                  href={`#${group.slug}`}
                  class="rounded-md border border-border bg-background px-4 py-2 text-sm font-semibold text-text-muted transition-colors hover:border-primary hover:text-primary"
                >
                  {group.label}
                </a>
              ))}
            </div>

            <div class="space-y-12">
              {accessoryGroups.map((group) => (
                <section id={group.slug} class="scroll-mt-28">
                  <div class="mb-5 max-w-3xl">
                    <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                      {group.label}
                    </h2>
                    <p class="mt-2 leading-relaxed text-text-muted">
                      {group.summary}
                    </p>
                  </div>

                  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                    {group.skus.map((sku) => (
                      <article class="group h-full overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-md">
                        <div class="flex h-full flex-col">
                          <div
                            class="relative flex aspect-[4/3] items-center justify-center overflow-hidden bg-surface p-6"
                            data-accessory-carousel={sku.images.length > 1 ? 'true' : undefined}
                          >
                            {sku.images.map((image, index) => (
                              <img
                                src={image.src}
                                alt={image.alt}
                                class:list={[
                                  'h-full w-full object-contain transition-all duration-300 group-hover:scale-105',
                                  sku.images.length > 1 && index !== 0 ? 'hidden' : '',
                                ]}
                                loading="lazy"
                                data-carousel-slide={sku.images.length > 1 ? String(index) : undefined}
                              />
                            ))}

                            {sku.images.length > 1 && (
                              <>
                                <button
                                  type="button"
                                  class="absolute left-3 top-1/2 inline-flex size-9 -translate-y-1/2 items-center justify-center rounded-md border border-border bg-background/90 text-text-muted shadow-sm transition-colors hover:bg-background hover:text-text"
                                  aria-label={`Previous ${sku.name} image`}
                                  data-carousel-prev
                                >
                                  <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                  </svg>
                                </button>
                                <button
                                  type="button"
                                  class="absolute right-3 top-1/2 inline-flex size-9 -translate-y-1/2 items-center justify-center rounded-md border border-border bg-background/90 text-text-muted shadow-sm transition-colors hover:bg-background hover:text-text"
                                  aria-label={`Next ${sku.name} image`}
                                  data-carousel-next
                                >
                                  <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                  </svg>
                                </button>
                                <div class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1.5">
                                  {sku.images.map((_, index) => (
                                    <button
                                      type="button"
                                      class:list={[
                                        'size-2 rounded-full border border-background/80 transition-colors',
                                        index === 0 ? 'bg-primary' : 'bg-text-muted/40',
                                      ]}
                                      aria-label={`Show ${sku.name} image ${index + 1}`}
                                      data-carousel-dot={String(index)}
                                    />
                                  ))}
                                </div>
                              </>
                            )}
                          </div>
                          <div class="flex flex-1 flex-col border-t border-border p-5">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
                              Accessory
                            </p>
                            <h3 class="mt-2 font-heading text-xl font-semibold leading-snug text-text">
                              {sku.name}
                            </h3>
                            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
                              {sku.description}
                            </p>
                            <p class="mt-4 text-xs font-semibold uppercase tracking-[0.16em] text-text-muted">
                              {group.label}
                            </p>
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Need Accessories For Your System?"
    description="Share your leak detector model and required accessory. We can help confirm compatibility and configuration."
    buttonText="Request Accessories"
    buttonHref="/contact"
  />

  <Footer slot="footer" />
</BaseLayout>

<script>
  function initAccessoryCarousels() {
    document.querySelectorAll<HTMLElement>('[data-accessory-carousel="true"]').forEach((carousel) => {
      if (carousel.dataset.carouselInit === 'true') return;
      carousel.dataset.carouselInit = 'true';

      const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
      const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
      const prevButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
      let activeIndex = 0;

      const setActiveSlide = (nextIndex: number) => {
        activeIndex = (nextIndex + slides.length) % slides.length;

        slides.forEach((slide, index) => {
          slide.classList.toggle('hidden', index !== activeIndex);
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle('bg-primary', index === activeIndex);
          dot.classList.toggle('bg-text-muted/40', index !== activeIndex);
        });
      };

      prevButton?.addEventListener('click', () => setActiveSlide(activeIndex - 1));
      nextButton?.addEventListener('click', () => setActiveSlide(activeIndex + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number(dot.getAttribute('data-carousel-dot'));
          if (!Number.isNaN(index)) setActiveSlide(index);
        });
      });

      setActiveSlide(0);
    });
  }

  initAccessoryCarousels();
  document.addEventListener('astro:after-swap', initAccessoryCarousels);
</script>
