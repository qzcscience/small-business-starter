---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import { brand } from '../../config/brand';
import { navItems } from '../../config/nav';
import heliumRecoveryImage from '../../assets/images/products/helium-recovery/wayeal-helium-recovery-system.png';
import workingPrincipleImage from '../../assets/images/products/helium-recovery/helium-recovery-working-principle.png';
import { createBreadcrumbSchema, getAbsoluteUrl, getCanonicalUrl } from '../../utils/seo';

const pageHref = '/products/helium-recovery';
const productName = 'Wayeal Helium Recovery System';
const pageTitle = productName;
const pageDescription =
  'Wayeal Helium Recovery System performs gross leak detection, helium filling, helium recovery, pressure and concentration monitoring, and automatic helium replenishment.';

const productLinks = navItems.find((item) => item.label === 'Products')?.children?.map((child) => ({
  label: child.label,
  href: child.href || '#',
  children: child.children,
})) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: productName },
];

const systemComponents = [
  'High-pressure tanks',
  'Low-pressure tanks',
  'Compressors',
  'Vacuum pumps',
  'Valves',
  'Pressure sensors',
  'Stainless steel pipelines',
];

const capabilities = [
  'Gross leak detection',
  'Helium filling',
  'Helium recovery',
  'Helium pressure monitoring',
  'Helium concentration monitoring',
  'Automatic helium replenishment',
];

const workingSteps = [
  {
    valve: 'V7',
    title: 'Evacuate the workpiece',
    description:
      'Open valve V7 to evacuate the workpiece under test. After evacuation, close V7.',
  },
  {
    valve: 'V1',
    title: 'Fill with helium',
    description:
      'Open valve V1 to fill the workpiece with helium. When the specified pressure is reached, close V1.',
  },
  {
    valve: 'V2',
    title: 'Transfer high-pressure helium',
    description:
      'After leak detection is completed, open V2 so the high-pressure helium inside the workpiece automatically flows into the low-pressure tank, then close V2.',
  },
  {
    valve: 'V3',
    title: 'Recover remaining helium',
    description:
      'Open V3; the mechanical pump extracts the remaining helium from the workpiece and sends it to the recovery tank.',
  },
  {
    valve: 'V4 + V5',
    title: 'Compress into the high-pressure tank',
    description:
      'When pressure in the recovery tank rises to the preset value, open V4 and V5 so the compressor compresses helium into the high-pressure tank.',
  },
  {
    valve: 'V6',
    title: 'Replenish pure helium',
    description:
      'Because 100% recovery is not possible, open V6 to supplement pure helium when pressure or concentration in the high-pressure tank is lower than the specified value.',
  },
];

const efficiencyFactors = [
  'Product evacuation level prior to helium charge',
  'Final helium charge pressure',
  'Part pressure level at the completion of recovery',
  'Cycle time',
  'Product volume',
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={heliumRecoveryImage.src}
  schema={[
    {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: productName,
      brand: {
        '@type': 'Brand',
        name: brand.name,
      },
      description: pageDescription,
      image: getAbsoluteUrl(heliumRecoveryImage.src),
      url: getCanonicalUrl(pageHref),
    },
    createBreadcrumbSchema(breadcrumbs),
  ]}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Products"
          categories={productLinks}
          activeHref={pageHref}
        />

        <article class="min-w-0 flex-1">
          <section class="overflow-hidden rounded-lg border border-border bg-background">
            <div class="grid gap-8 p-6 sm:p-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(340px,1.08fr)] lg:items-center lg:p-10">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                  Helium recovery system
                </p>
                <h1 class="mt-3 font-heading text-4xl font-bold uppercase leading-tight text-text sm:text-5xl">
                  {productName}
                </h1>
                <p class="mt-5 max-w-2xl text-lg leading-relaxed text-text-muted">
                  The helium recovery system mainly consists of high-pressure tanks,
                  low-pressure tanks, compressors, vacuum pumps, valves, pressure sensors,
                  and stainless steel pipelines.
                </p>
                <p class="mt-4 max-w-2xl leading-relaxed text-text-muted">
                  It can perform gross leak detection, helium filling, helium recovery,
                  and other processes on workpieces within the set time.
                </p>

                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                  <a
                    href="/contact"
                    class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                  >
                    Discuss Helium Recovery
                  </a>
                  <a
                    href="#working-process"
                    class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-border px-6 py-3 text-base font-bold text-text transition-colors hover:border-primary hover:bg-surface"
                  >
                    View Working Process
                  </a>
                </div>
              </div>

              <div>
                <img
                  src={heliumRecoveryImage.src}
                  width={heliumRecoveryImage.width}
                  height={heliumRecoveryImage.height}
                  alt="Wayeal Helium Recovery System"
                  class="h-auto w-full rounded-md bg-surface object-contain"
                />
              </div>
            </div>
          </section>

          <section class="mt-10 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                System composition
              </p>
              <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                Main modules and pipelines
              </h2>
              <p class="mt-4 leading-relaxed text-text-muted">
                The system is built around tanks, pumping, compression, valves,
                sensing, and stainless steel pipeline connections.
              </p>
            </div>

            <ul class="grid gap-3 sm:grid-cols-2">
              {systemComponents.map((component) => (
                <li class="rounded-md border border-border bg-background px-4 py-3 text-sm font-semibold text-text">
                  {component}
                </li>
              ))}
            </ul>
          </section>

          <section class="mt-10 grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                Monitoring and replenishment
              </p>
              <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                Pressure, concentration, and automatic helium supply
              </h2>
              <p class="mt-4 leading-relaxed text-text-muted">
                The system is equipped with helium pressure and concentration monitoring
                functions, as well as an automatic helium replenishment function.
              </p>
              <p class="mt-4 leading-relaxed text-text-muted">
                When the system detects that helium concentration or pressure is lower
                than the set value, it automatically opens the valve to supplement
                high-purity helium.
              </p>
            </div>

            <ul class="grid gap-3">
              {capabilities.map((capability) => (
                <li class="flex gap-3 rounded-md border border-border bg-surface px-4 py-3">
                  <span class="mt-1 size-2 shrink-0 rounded-full bg-accent"></span>
                  <span class="text-sm font-medium leading-relaxed text-text">{capability}</span>
                </li>
              ))}
            </ul>
          </section>

          <section id="working-process" class="mt-10 scroll-mt-28">
            <div class="max-w-3xl">
              <h2 class="font-heading text-h2 font-semibold uppercase text-text">
                II System Working Principle
              </h2>
            </div>

            <figure class="mt-6 overflow-hidden rounded-lg border border-border bg-background">
              <img
                src={workingPrincipleImage.src}
                width={workingPrincipleImage.width}
                height={workingPrincipleImage.height}
                alt="Wayeal Helium Recovery System working principle diagram"
                class="h-auto w-full object-contain"
                loading="lazy"
              />
            </figure>

            <ol class="mt-6 space-y-4">
              {workingSteps.map((step, index) => (
                <li>
                  <article class="rounded-md border border-border bg-background p-5 sm:flex sm:gap-5">
                    <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-fg">
                      {index + 1}
                    </div>
                    <div class="mt-4 min-w-0 sm:mt-0">
                      <p class="text-sm font-bold uppercase tracking-[0.14em] text-primary">
                        {step.valve}
                      </p>
                      <h3 class="mt-1 font-heading text-xl font-semibold uppercase text-text">
                        {step.title}
                      </h3>
                      <div class="mt-3 space-y-3">
                        <p class="text-sm leading-relaxed text-text-muted">
                          {step.description}
                        </p>
                      </div>
                    </div>
                  </article>
                </li>
              ))}
            </ol>
          </section>

          <section class="mt-10 rounded-lg border border-border bg-surface p-6 sm:p-8">
            <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                  Important note
                </p>
                <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                  Actual efficiency of 98%
                </h2>
              </div>

              <div>
                <p class="leading-relaxed text-text-muted">
                  Actual efficiency of 98% will be dependent on the product evacuation
                  level prior to helium charge, final helium charge pressure, part
                  pressure level at the completion of recovery, cycle time, and product
                  volume.
                </p>
                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  {efficiencyFactors.map((factor) => (
                    <div class="rounded-md border border-border bg-background px-4 py-3 text-sm font-medium text-text">
                      {factor}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>

          <section class="mt-10 overflow-hidden rounded-lg bg-primary p-6 text-primary-fg sm:p-8">
            <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
              <div>
                <h2 class="font-heading text-3xl font-bold uppercase text-primary-fg">
                  Discuss {productName}
                </h2>
                <p class="mt-3 max-w-2xl leading-relaxed text-primary-fg/80">
                  Share the workpiece, helium charge pressure, cycle time, and recovery
                  requirements for your process.
                </p>
              </div>
              <a
                href="/contact"
                class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              >
                Contact Wayeal
              </a>
            </div>
          </section>
        </article>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
