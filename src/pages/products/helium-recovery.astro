---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../../components/atoms/CategorySidebar.astro';
import { brand } from '../../config/brand';
import { navItems } from '../../config/nav';
import heliumRecoveryImage from '../../assets/images/products/helium-recovery/wyh-531-helium-recovery-system.png';

const pageHref = '/products/helium-recovery';
const productName = 'WYH-531 Helium Recovery System';
const pageTitle = productName;
const pageDescription =
  'Wayeal WYH-531 Helium Recovery System helps production teams recover and reuse helium from leak testing workflows, with actual recovery efficiency up to 98%.';

const productLinks = navItems.find((item) => item.label === 'Products')?.children?.map((child) => ({
  label: child.label,
  href: child.href || '#',
  children: child.children,
})) || [];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: productName },
];

const efficiencyFactors = [
  'Product evacuation level before helium charge',
  'Final helium charge pressure',
  'Part pressure level at recovery completion',
  'Cycle time',
  'Product volume',
];

const benefits = [
  {
    title: 'Reduce helium consumption',
    description:
      'Recover helium after test cycles and return it to the process instead of exhausting usable gas.',
  },
  {
    title: 'Stabilize production cost',
    description:
      'Support high-volume leak testing lines where helium usage has a direct impact on operating cost.',
  },
  {
    title: 'Fit existing test workflows',
    description:
      'Designed for integration with helium charge, recovery, and leak detection processes around industrial parts.',
  },
];

const workflow = [
  'Evacuate',
  'Charge',
  'Recover',
  'Reuse',
];

const applications = [
  'Vacuum chamber leak detection systems',
  'Industrial helium leak testing lines',
  'Automotive and HVAC component testing',
  'Batch production environments using helium as tracer gas',
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={heliumRecoveryImage.src}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: productName,
    brand: {
      '@type': 'Brand',
      name: brand.name,
    },
    description: pageDescription,
    image: heliumRecoveryImage.src,
  }}
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="Products"
          categories={productLinks}
          activeHref={pageHref}
        />

        <article class="min-w-0 flex-1">
          <section class="overflow-hidden rounded-lg border border-border bg-background">
            <div class="grid gap-8 p-6 sm:p-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(360px,1.1fr)] lg:items-center lg:p-10">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                  Helium recovery
                </p>
                <h1 class="mt-3 font-heading text-4xl font-bold uppercase leading-tight text-text sm:text-5xl">
                  WYH-531 Helium Recovery System
                </h1>
                <p class="mt-5 max-w-2xl text-lg leading-relaxed text-text-muted">
                  Recover and reuse helium in production leak testing workflows while keeping gas usage,
                  cycle planning, and process integration under tighter control.
                </p>

                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                  <a
                    href="/contact"
                    class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                  >
                    Request Configuration Support
                  </a>
                  <a
                    href="#efficiency"
                    class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-border px-6 py-3 text-base font-bold text-text transition-colors hover:border-primary hover:bg-surface"
                  >
                    View Efficiency Details
                  </a>
                </div>
              </div>

              <div class="relative">
                <div class="absolute right-4 top-4 z-10 rounded-md bg-primary px-4 py-3 text-primary-fg shadow-lg">
                  <div class="text-xs font-semibold uppercase tracking-[0.16em] opacity-80">Actual efficiency</div>
                  <div class="font-heading text-4xl font-bold leading-none">98%</div>
                </div>
                <img
                  src={heliumRecoveryImage.src}
                  width={heliumRecoveryImage.width}
                  height={heliumRecoveryImage.height}
                  alt="WYH-531 helium recovery system"
                  class="h-auto w-full rounded-md bg-surface object-contain"
                />
              </div>
            </div>
          </section>

          <section id="efficiency" class="mt-8 rounded-lg border border-border bg-surface p-6 sm:p-8">
            <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                  Efficiency context
                </p>
                <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                  Up to 98% actual recovery efficiency
                </h2>
              </div>
              <div class="text-text-muted">
                <p class="leading-relaxed">
                  Actual efficiency will be dependent on the product evacuation level prior to helium
                  charge, final charge pressure, part pressure level at the completion of recovery,
                  cycle time, and product volume.
                </p>
                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  {efficiencyFactors.map((factor) => (
                    <div class="rounded-md border border-border bg-background px-4 py-3 text-sm font-medium text-text">
                      {factor}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>

          <section class="mt-10">
            <div class="max-w-3xl">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                Why recovery matters
              </p>
              <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                Built for helium-intensive leak testing operations
              </h2>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-3">
              {benefits.map((benefit) => (
                <div class="rounded-lg border border-border bg-background p-5">
                  <h3 class="font-heading text-xl font-semibold uppercase text-text">
                    {benefit.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-text-muted">
                    {benefit.description}
                  </p>
                </div>
              ))}
            </div>
          </section>

          <section class="mt-10 rounded-lg border border-border bg-background p-6 sm:p-8">
            <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                  Recovery workflow
                </p>
                <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                  From test gas to reusable supply
                </h2>
                <p class="mt-4 leading-relaxed text-text-muted">
                  The system supports a practical production loop around helium charging and recovery,
                  helping teams reuse tracer gas without disrupting the leak testing sequence.
                </p>
              </div>

              <ol class="grid gap-3 sm:grid-cols-4">
                {workflow.map((step, index) => (
                  <li class="rounded-md border border-border bg-surface p-4 text-center">
                    <div class="mx-auto flex size-10 items-center justify-center rounded-full bg-primary font-bold text-primary-fg">
                      {index + 1}
                    </div>
                    <div class="mt-3 font-heading text-lg font-semibold uppercase text-text">
                      {step}
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </section>

          <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_0.85fr] lg:items-start">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
                Applications
              </p>
              <h2 class="mt-2 font-heading text-3xl font-bold uppercase text-text">
                Suitable for industrial helium test environments
              </h2>
              <p class="mt-4 leading-relaxed text-text-muted">
                WYH-531 is intended for production environments where helium is used as a tracer gas
                and recovery can improve total gas utilization across repeated test cycles.
              </p>
            </div>

            <ul class="grid gap-3">
              {applications.map((application) => (
                <li class="flex gap-3 rounded-md border border-border bg-background px-4 py-3">
                  <span class="mt-1 size-2 shrink-0 rounded-full bg-accent"></span>
                  <span class="text-sm font-medium leading-relaxed text-text">{application}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="mt-10 overflow-hidden rounded-lg bg-primary p-6 text-primary-fg sm:p-8">
            <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
              <div>
                <h2 class="font-heading text-3xl font-bold uppercase text-primary-fg">
                  Configure helium recovery for your line
                </h2>
                <p class="mt-3 max-w-2xl leading-relaxed text-primary-fg/80">
                  Share your product volume, cycle time, charge pressure, and recovery target so our
                  team can help match the system to your process.
                </p>
              </div>
              <a
                href="/contact"
                class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              >
                Get a Quote
              </a>
            </div>
          </section>
        </article>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
