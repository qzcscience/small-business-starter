---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/atoms/Breadcrumb.astro';
import CategorySidebar from '../components/atoms/CategorySidebar.astro';
import CTA from '../components/CTA.astro';
import {
  ABOUT_BASE_PATH,
  aboutNavItems,
  aboutSections,
} from '../data/about';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About Us' },
];
---

<BaseLayout
  title="About Us"
  description="Explore Wayeal company profile, factory capability, culture, team, certifications, research collaboration, and ESG information."
>
  <Header slot="header" />

  <Breadcrumb items={breadcrumbs} />

  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
        <CategorySidebar
          title="About Us"
          rootHref={ABOUT_BASE_PATH}
          categories={aboutNavItems}
        />

        <div class="min-w-0 flex-1">
          <div class="rounded-lg border border-border bg-background shadow-sm">
            <div class="border-b border-border bg-surface/60 px-6 py-6 sm:px-8 lg:px-10">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                Company Center
              </p>
              <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h1 class="font-heading text-h1 font-bold uppercase leading-tight text-text">
                    About Us
                  </h1>
                  <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-muted sm:text-lg">
                    Learn about Wayeal's company profile, manufacturing capability,
                    engineering culture, team structure, qualifications, research
                    collaboration, and ESG direction.
                  </p>
                </div>
                <p class="text-sm font-medium text-text-muted">
                  {aboutSections.length} Sections
                </p>
              </div>
            </div>

            <div class="divide-y divide-border">
              {aboutSections.map((section) => (
                <section id={section.slug} class="scroll-mt-28 px-5 py-8 sm:px-6 lg:px-8 lg:py-10">
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
                        {section.eyebrow}
                      </p>
                      <h2 class="mt-3 font-heading text-h2 font-semibold uppercase leading-tight text-text">
                        {section.title}
                      </h2>
                    </div>
                    <a
                      href={section.href}
                      class="inline-flex min-h-[40px] items-center rounded-md border border-border px-4 py-2 text-sm font-semibold text-primary transition-colors hover:border-primary/40 hover:bg-surface"
                    >
                      Open detail
                    </a>
                  </div>

                  <p class="mt-4 max-w-4xl text-base leading-relaxed text-text-muted">
                    {section.summary}
                  </p>

                  <ul class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-3" role="list">
                    {section.highlights.map((highlight) => (
                      <li class="border-l-2 border-primary/40 bg-surface/60 px-4 py-3 text-sm leading-relaxed text-text-muted">
                        {highlight}
                      </li>
                    ))}
                  </ul>

                  <div class="mt-7 grid grid-cols-1 gap-6 lg:grid-cols-2">
                    {section.blocks.map((block) => (
                      <section>
                        <h3 class="font-heading text-h3 font-semibold uppercase leading-tight text-text">
                          {block.title}
                        </h3>
                        <div class="mt-3 space-y-3">
                          {block.body.map((paragraph) => (
                            <p class="text-sm leading-relaxed text-text-muted sm:text-base">
                              {paragraph}
                            </p>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
